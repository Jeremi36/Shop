<%- include('layout-top') %>
<h1>Mein Konto</h1>
<% if (success) { %><p class="success"><%= success %></p><% } %>
<% if (error) { %><p class="error"><%= error %></p><% } %>
<% if (user.banned) { %><p class="error">Dein Konto ist gesperrt: <%= user.ban_reason || 'Kein Grund angegeben' %>. Über das Supportfenster kannst du Einspruch einlegen.</p><% } %>
<% if (user.temporary_suspended_until && new Date(user.temporary_suspended_until)>new Date()) { %><p class="error">Bestellungen sind bis <%= new Date(user.temporary_suspended_until).toLocaleString('de-DE') %> gesperrt. <%= user.temporary_suspension_reason || '' %></p><% } %>

<div class="grid account-grid">
<section class="panel">
  <h2>Kontodaten</h2>
  <p class="muted">Änderungen gelten nur für neue Bestellungen. Bereits aufgegebene Bestellungen behalten die damals gespeicherten Daten.</p>
  <form method="post" action="/account" class="stack">
    <label>Vollständiger Name<input name="full_name" required value="<%= user.full_name %>"></label>
    <label>Straße und Hausnummer<input name="street" required value="<%= user.street %>"></label>
    <label>Postleitzahl<input name="postal_code" required value="<%= user.postal_code %>"></label>
    <label>Ort<input name="city" required value="<%= user.city %>"></label>
    <label>Telefonnummer (optional)<input name="phone" value="<%= user.phone || '' %>"></label>
    <button>Daten speichern</button>
  </form>
</section>

<section class="panel">
  <h2>Rang: <a href="/rollen"><%= roleLabel(user.role) %></a></h2>
  <% if (isCustomer) { %>
    <p><b><%= rankStats.order_count || 0 %></b> abgeschlossene Bestellungen · <b><%= money(rankStats.spent_cents || 0) %></b> ausgegeben</p>
    <p class="muted">Öffne die Rangübersicht, um Vorteile, Fortschritt und gesperrte Ränge zu sehen.</p>
    <a class="btn" href="/rollen">Rangübersicht öffnen</a>
  <% } else { %>
    <p class="muted">Die Rollenübersicht zeigt deine Rechte und die Vorteile der anderen Mitarbeiterrollen.</p>
    <a class="btn" href="/rollen">Rollenübersicht öffnen</a>
  <% } %>
</section>
</div>

<% if (isCustomer) { %>
<div class="grid account-credit-grid">
<section class="panel">
  <h2>Guthaben: <%= money(user.credit_cents || 0) %></h2>
  <form method="post" action="/account/redeem-gift-card" class="inline">
    <input name="code" required placeholder="Gutscheincode">
    <button>Gutschein einlösen</button>
  </form>
  <h3>Letzte Guthabenbewegungen</h3>
  <div class="credit-list">
    <% if (!(creditTransactions||[]).length) { %><p class="muted">Noch keine Guthabenbewegungen.</p><% } %>
    <% (creditTransactions||[]).forEach(t=>{ %>
      <p><b class="<%= t.amount_cents>=0?'positive':'negative' %>"><%= t.amount_cents>=0?'+':'' %><%= money(t.amount_cents) %></b> · <%= t.note || t.transaction_type %><br><small><%= new Date(t.created_at).toLocaleString('de-DE') %></small></p>
    <% }) %>
  </div>
</section>

<section class="panel">
  <h2>E-Mail-Mitteilungen</h2>
  <p class="muted">Mitteilungen in der Website bleiben erhalten. Hier entscheidest du nur, welche davon zusätzlich per E-Mail verschickt werden.</p>
  <form method="post" action="/account/benachrichtigungen" class="stack check-list email-preferences">
    <label><input type="checkbox" name="email_notifications_enabled" data-email-master <%= user.email_notifications_enabled?'checked':'' %>> E-Mails grundsätzlich erlauben</label>
    <label class="email-option"><input type="checkbox" name="email_order_updates" data-email-child <%= user.email_order_updates?'checked':'' %>> Bestell- und Terminänderungen</label>
    <label class="email-option"><input type="checkbox" name="email_support_updates" data-email-child <%= user.email_support_updates?'checked':'' %>> Supportantworten</label>
    <label class="email-option"><input type="checkbox" name="email_discount_updates" data-email-child <%= user.email_discount_updates?'checked':'' %>> Rabattcodes und Wochenvorteile</label>
    <label class="email-option"><input type="checkbox" name="email_gift_card_updates" data-email-child <%= user.email_gift_card_updates?'checked':'' %>> Gutscheine</label>
    <label class="email-option"><input type="checkbox" name="email_rank_updates" data-email-child <%= user.email_rank_updates?'checked':'' %>> Rangaufstiege und Cashback</label>
    <button>Einstellungen speichern</button>
  </form>
</section>
</div>

<section class="panel">
  <div class="section-head"><div><h2>Meine Gutscheinbestellungen</h2><p class="muted">Gestalte neue Gutscheine direkt auf der Gutscheinseite.</p></div><a class="btn" href="/gutschein">Gutschein gestalten</a></div>
  <% if (!(giftOrders||[]).length) { %><p class="muted">Noch keine Gutscheine bestellt.</p><% } else { %>
  <table><tr><th>Datum</th><th>Wert</th><th>Empfänger</th><th>Ausgabe</th><th>Status</th><th>Aktion</th></tr>
    <% giftOrders.forEach(g=>{ %><tr>
      <td><%= new Date(g.created_at).toLocaleString('de-DE') %></td>
      <td><%= money(g.amount_cents) %></td>
      <td><%= g.recipient_name || '-' %></td>
      <td><%= g.delivery_method==='email' ? 'Per E-Mail an ' + g.delivery_email : 'PDF herunterladen' %></td>
      <td><%= giftStatusDe(g.status) %></td>
      <td><% if(g.gift_card_id && g.delivery_method!=='email'){ %><a class="btn" href="/gift-cards/<%= g.gift_card_id %>/pdf?token=<%= encodeURIComponent(g.download_token) %>">PDF herunterladen</a><% } else if(g.gift_card_id){ %><span class="success">PDF wurde versendet</span><% } else { %>-<% } %></td>
    </tr><% }) %>
  </table>
  <% } %>
</section>
<% } else { %>
<section class="panel">
  <h2>E-Mail-Mitteilungen</h2>
  <form method="post" action="/account/benachrichtigungen" class="stack check-list email-preferences">
    <label><input type="checkbox" name="email_notifications_enabled" data-email-master <%= user.email_notifications_enabled?'checked':'' %>> E-Mails grundsätzlich erlauben</label>
    <label class="email-option"><input type="checkbox" name="email_order_updates" data-email-child <%= user.email_order_updates?'checked':'' %>> Bestelländerungen</label>
    <label class="email-option"><input type="checkbox" name="email_support_updates" data-email-child <%= user.email_support_updates?'checked':'' %>> Support</label>
    <label class="email-option"><input type="checkbox" name="email_discount_updates" data-email-child <%= user.email_discount_updates?'checked':'' %>> Rabattcodes</label>
    <label class="email-option"><input type="checkbox" name="email_gift_card_updates" data-email-child <%= user.email_gift_card_updates?'checked':'' %>> Gutscheine</label>
    <label class="email-option"><input type="checkbox" name="email_rank_updates" data-email-child <%= user.email_rank_updates?'checked':'' %>> Rollenänderungen</label>
    <button>Einstellungen speichern</button>
  </form>
</section>
<% } %>

<script>
(() => {
  document.querySelectorAll('.email-preferences').forEach(form => {
    const master=form.querySelector('[data-email-master]');
    const children=[...form.querySelectorAll('[data-email-child]')];
    if(!master)return;
    const sync=()=>children.forEach(input=>{const row=input.closest('.email-option');if(!master.checked)input.checked=false;input.disabled=!master.checked;row?.classList.toggle('is-disabled',!master.checked);});
    master.addEventListener('change',sync);sync();
  });
})();
</script>
<%- include('layout-bottom') %>
