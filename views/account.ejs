<%- include('layout-top') %>
<h1>Mein Konto</h1>
<% if (success) { %><p class="success"><%= success %></p><% } %><% if (error) { %><p class="error"><%= error %></p><% } %>
<% if (user.banned) { %><p class="error">Dein Account ist gesperrt: <%= user.ban_reason || 'Kein Grund angegeben' %>. Du kannst über das Support-Fenster unten rechts Einspruch einlegen.</p><% } %>
<% if (user.temporary_suspended_until && new Date(user.temporary_suspended_until)>new Date()) { %><p class="error">Bestellungen sind bis <%= new Date(user.temporary_suspended_until).toLocaleString('de-DE') %> gesperrt. <%= user.temporary_suspension_reason || '' %> Nutze das Support-Fenster für Rückfragen.</p><% } %>
<section class="panel"><h2>Kontodaten</h2><p class="muted">Änderungen gelten nur für neue Bestellungen. Vorhandene Bestellungen behalten die damals gespeicherten Daten.</p><form method="post" action="/account" class="stack"><label>Vollständiger Name<input name="full_name" required value="<%= user.full_name %>"></label><label>Straße + Hausnummer<input name="street" required value="<%= user.street %>"></label><label>PLZ<input name="postal_code" required value="<%= user.postal_code %>"></label><label>Ort<input name="city" required value="<%= user.city %>"></label><label>Telefon optional<input name="phone" value="<%= user.phone || '' %>"></label><p><b>Altersstatus:</b> <%= verificationLabel(user.verification_level) %></p><button>Daten speichern</button></form></section>
<% if (isCustomer) { %>
<div class="grid account-credit-grid">
<section class="panel"><h2>Guthaben: <%= money(user.credit_cents || 0) %></h2><form method="post" action="/account/redeem-gift-card" class="inline"><input name="code" required placeholder="Gutscheincode"><button>Gutschein einlösen</button></form><h3>Letzte Bewegungen</h3><div class="credit-list"><% (creditTransactions||[]).forEach(t=>{ %><p><b class="<%= t.amount_cents>=0?'positive':'negative' %>"><%= t.amount_cents>=0?'+':'' %><%= money(t.amount_cents) %></b> · <%= t.note || t.transaction_type %><br><small><%= new Date(t.created_at).toLocaleString('de-DE') %></small></p><% }) %></div></section>
<section class="panel"><h2>Gutschein kaufen</h2><p class="muted">Wert auswählen, Nachricht hinzufügen und Anfrage absenden. Ein Staff bestätigt die Zahlung; danach werden Code und PDF automatisch bereitgestellt.</p><form method="post" action="/gift-cards/request" class="stack"><label>Wert in €<input name="amount" type="number" min="5" max="500" step="0.01" required></label><label>Nachricht auf der Karte<textarea name="custom_message" maxlength="500" placeholder="Alles Gute!"></textarea></label><button>Gutschein anfragen</button></form></section>
</div>
<section class="panel"><h2>Meine Gutschein-Anfragen</h2><table><tr><th>Datum</th><th>Wert</th><th>Status</th><th>Code/PDF</th></tr><% (giftOrders||[]).forEach(g=>{ %><tr><td><%= new Date(g.created_at).toLocaleString('de-DE') %></td><td><%= money(g.amount_cents) %></td><td><%= g.status %></td><td><% if(g.gift_card_id){ %><code><%= g.code %></code><br><a href="/gift-cards/<%= g.gift_card_id %>/pdf?token=<%= encodeURIComponent(g.download_token) %>">PDF herunterladen</a><% } else { %>-<% } %></td></tr><% }) %></table></section>
<% } %>
<%- include('layout-bottom') %>
