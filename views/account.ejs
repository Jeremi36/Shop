<%- include('layout-top') %>
<h1>Mein Konto</h1>
<% if (success) { %><p class="success"><%= success %></p><% } %>
<% if (error) { %><p class="error"><%= error %></p><% } %>
<section class="panel">
  <h2>Kontodaten</h2>
  <p class="muted">Änderungen gelten nur für neue Bestellungen. Bereits aufgegebene Bestellungen behalten die damals gespeicherten Daten.</p>
  <form method="post" action="/account" class="stack">
    <label>Vollständiger Name<input name="full_name" required value="<%= user.full_name %>"></label>
    <label>Straße + Hausnummer<input name="street" required value="<%= user.street %>"></label>
    <label>PLZ<input name="postal_code" required value="<%= user.postal_code %>"></label>
    <label>Ort<input name="city" required value="<%= user.city %>"></label>
    <label>Telefon optional<input name="phone" value="<%= user.phone || '' %>"></label>
    <p><b>Altersstatus:</b> <%= verificationLabel(user.verification_level) %></p>
    <button>Daten speichern</button>
  </form>
</section>
<%- include('layout-bottom') %>
