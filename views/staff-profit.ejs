<%- include('layout-top') %><h1>Profit Übersicht</h1>
<div class="grid"><div class="card"><h2><%= money(summary.day_profit) %></h2><p>Heute</p></div><div class="card"><h2><%= money(summary.week_profit) %></h2><p>Diese Woche</p></div><div class="card"><h2><%= money(summary.month_profit) %></h2><p>Diesen Monat</p></div><div class="card"><h2><%= money(summary.total_profit) %></h2><p>Gesamt</p></div></div>
<section class="panel"><p><b>Umsatz:</b> <%= money(summary.total_revenue) %> · <b>Einkaufskosten:</b> <%= money(summary.total_cost) %> · <b>Profit:</b> <%= money(summary.total_profit) %></p></section>
<table><tr><th>Produkt</th><th>Sorte</th><th>Verkauft</th><th>Umsatz</th><th>Kosten</th><th>Profit</th><th>Profit %</th></tr><% items.forEach(i=>{ const pct = i.cost>0 ? Math.round((i.profit/i.cost)*100) : 0; %><tr><td><%= i.product_name %></td><td><%= i.variant_name || '-' %></td><td><%= i.qty %></td><td><%= money(i.revenue) %></td><td><%= money(i.cost) %></td><td><%= money(i.profit) %></td><td><%= pct %>%</td></tr><% }) %></table><%- include('layout-bottom') %>
