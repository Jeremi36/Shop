<%- include('layout-top') %><h1>Profit Übersicht</h1>
<div class="grid"><div class="card"><h2><%= money(summary.day_profit) %></h2><p>Heute</p></div><div class="card"><h2><%= money(summary.week_profit) %></h2><p>Diese Woche</p></div><div class="card"><h2><%= money(summary.month_profit) %></h2><p>Diesen Monat</p></div><div class="card"><h2><%= money(summary.total_profit) %></h2><p>Gesamt netto</p></div></div>
<section class="panel"><p><b>Umsatz:</b> <%= money(summary.total_revenue) %> · <b>Einkaufskosten:</b> <%= money(summary.total_cost) %> · <b>Extra-Kosten:</b> <%= money(summary.total_extra_cost || 0) %> · <b>Netto-Profit:</b> <%= money(summary.total_profit) %></p></section>
<table><tr><th>Produkt</th><th>Sorte</th><th>Verkauft</th><th>Umsatz</th><th>Kosten</th><th>Brutto-Profit</th><th>Profit %</th></tr><% items.forEach(i=>{ const pct = i.cost>0 ? Math.round((i.profit/i.cost)*100) : 0; %><tr><td><%= i.product_name %></td><td><%= i.variant_name || '-' %></td><td><%= i.qty %></td><td><%= money(i.revenue) %></td><td><%= money(i.cost) %></td><td><%= money(i.profit) %></td><td><%= pct %>%</td></tr><% }) %></table>
<section class="panel"><h2>Extra-Kosten bei Bestellungen</h2><table><tr><th>Datum</th><th>Bestellung</th><th>Extra-Kosten</th><th>Notiz</th></tr><% (extraOrders||[]).forEach(o=>{ %><tr><td><%= new Date(o.created_at).toLocaleString('de-DE') %></td><td><a href="/orders/<%= o.id %>">Details</a></td><td><%= money(o.extra_cost_cents) %></td><td><%= o.extra_cost_note || '-' %></td></tr><% }) %></table></section>
<%- include('layout-bottom') %>
