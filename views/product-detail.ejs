<%- include('layout-top') %>
<section class="panel">
  <p><a href="/">← Zurück zu den Produkten</a></p>
  <div class="grid product-detail-grid">
    <div class="product-detail-image-box">
      <% if (product.image_url) { %><img src="<%= product.image_url %>" alt="<%= product.name %>" class="product-detail-image"><% } else if(product.product_type==='gift_card'){ %><div class="gift-placeholder gift-detail-placeholder">🎁<span>Geschenkgutschein</span></div><% } else { %><div class="placeholder product-detail-placeholder">Kein Bild</div><% } %>
    </div>
    <div>
      <p class="muted"><%= product.category_name || 'Allgemein' %><% if(product.age_level>0){ %> · <span class="sale"><%= product.age_level %>+</span><% } %></p>
      <h1><%= product.name %></h1>
      <p><%= product.description %></p>

      <% if(product.product_type==='gift_card'){ %>
        <% if(!user){ %><p class="notice">Zum Gestalten und Bestellen eines Gutscheins musst du dich einloggen.</p><a class="btn" href="/login">Einloggen</a>
        <% } else if(!isCustomer){ %><p class="notice">Gutscheine können nur mit einem Kundenkonto bestellt werden.</p>
        <% } else { %>
          <form method="post" action="/gift-cards/request" class="panel stack gift-builder" id="gift-builder">
            <h2>Gutschein gestalten</h2>
            <label>Gutscheinwert in Euro<input name="amount" type="number" min="<%= (product.gift_card_min_cents||500)/100 %>" max="<%= (product.gift_card_max_cents||50000)/100 %>" step="0.01" value="25" required></label>
            <div class="two-col">
              <label>Für wen?<input name="recipient_name" maxlength="120" placeholder="Name des Empfängers" required></label>
              <label>Von wem?<input name="sender_name" maxlength="120" value="<%= user.full_name || '' %>" required></label>
            </div>
            <label>Persönliche Nachricht<textarea name="custom_message" maxlength="500" placeholder="Viel Freude mit deinem Gutschein!"></textarea></label>
            <fieldset class="gift-themes"><legend>Gestaltung auswählen</legend>
              <% [['blau','Blau'],['gold','Gold'],['rosa','Rosa'],['dunkel','Dunkel'],['festlich','Festlich']].forEach((t,i)=>{ %><label class="gift-theme theme-<%= t[0] %>"><input type="radio" name="design_theme" value="<%= t[0] %>" <%= i===0?'checked':'' %>><span><%= t[1] %></span></label><% }) %>
            </fieldset>
            <fieldset><legend>Ausgabe auswählen</legend>
              <label class="legal-check"><input type="radio" name="delivery_method" value="download" checked data-delivery> PDF in meinem Konto herunterladen</label>
              <label class="legal-check"><input type="radio" name="delivery_method" value="email" data-delivery> PDF automatisch per E-Mail versenden</label>
            </fieldset>
            <label id="gift-email-field" hidden>Empfänger-E-Mail-Adresse<input name="delivery_email" type="email" placeholder="empfaenger@beispiel.de"></label>
            <p class="muted">Der Gutscheincode steht ausschließlich in der erzeugten PDF. Die PDF wird erst nach bestätigter Zahlung erstellt.</p>
            <button>Gutschein zahlungspflichtig anfragen</button>
          </form>
          <script>document.querySelectorAll('[data-delivery]').forEach(r=>r.addEventListener('change',()=>{const e=document.getElementById('gift-email-field');const active=document.querySelector('[name=delivery_method]:checked').value==='email';e.hidden=!active;e.querySelector('input').required=active;}));</script>
        <% } %>
      <% } else { %>
        <p><% if (product.discount_percent > 0) { %><span class="old"><%= money(product.price_cents) %></span> <b><%= money(discounted(product)) %></b> <span class="sale">−<%= product.discount_percent %>%</span><% } else { %><b><%= money(product.price_cents) %></b><% } %></p>
        <div class="grid smallgrid">
          <div class="card"><h2><%= product.views_count || 0 %></h2><p>Aufrufe</p></div>
          <div class="card"><h2><%= stats.sold_count || 0 %></h2><p>Gekauft</p></div>
          <div class="card"><h2><%= stats.avg_rating || 0 %>★</h2><p><%= stats.review_count || 0 %> Bewertungen</p></div>
        </div>
        <% if (product.supplier_url && product.supplier_status === 'out_of_stock') { %><div class="notice"><b>Nicht auf Lager</b></div><% } %>
        <% if (isStaff && hasPermission('can_view_staff_notes')) { %><div class="notice"><b>Interne Produktinformationen</b><br>Einkaufspreis: <%= money(product.purchase_price_cents || 0) %> · Zielprofit: <%= product.target_profit_percent || 0 %>%<% if (product.staff_note) { %><br><b>Notiz:</b><pre><%= product.staff_note %></pre><% } %><% if (product.supplier_url) { %><a href="<%= product.supplier_url %>" target="_blank" rel="noopener">Nachkauflink öffnen</a><% } %></div><% } %>
        <% const stock = variants.length ? variants.reduce((s,v)=>s+Number(v.stock||0),0) : product.stock; %>
        <% if (agePurchaseError) { %><div class="notice"><b>Altersfreigabe erforderlich</b><br><%= agePurchaseError %></div><% } %>
        <% if (isCustomer) { %><form method="post" action="/cart/add/<%= product.id %>" class="inline panel"><% if (variants.length) { %><select name="variant_id" required><option value="">Sorte wählen</option><% variants.forEach(v => { %><option value="<%= v.id %>"><%= v.name %> · Lager <%= v.stock %></option><% }) %></select><% } %><input type="number" name="quantity" min="1" max="<%= stock %>" value="1"><button <%= stock <= 0 ? 'disabled' : '' %>>In den Warenkorb</button></form>
        <% } else if (!user) { %><a class="btn" href="/login">Zum Kaufen einloggen</a><% } %>
      <% } %>
    </div>
  </div>
</section>

<% if(product.product_type!=='gift_card'){ %>
<section class="panel">
  <h2>Bewertungen</h2>
  <% if (!reviews.length) { %><p class="muted">Noch keine Bewertungen.</p><% } %>
  <% reviews.forEach(r => { %><div class="card review-card"><b><%= r.rating %>★ · <%= r.full_name %></b><p><%= r.comment || 'Keine Nachricht' %></p><% if (r.image_url) { %><img class="review-img" src="<%= r.image_url %>" alt="Bild zur Bewertung"><% } %><small><%= new Date(r.created_at).toLocaleString('de-DE') %></small></div><% }) %>
</section>
<% } %>
<%- include('layout-bottom') %>
