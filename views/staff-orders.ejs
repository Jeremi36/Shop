<%- include('layout-top') %><h1>Bestellungen</h1>
<% if(isOwner){ %><p class="notice">Neue Bestellungen werden nicht automatisch zugeteilt. Weise sie hier manuell einem Staff zu.</p><% } %>
<div class="chips"><% ['Placed','Accepted','Denied','Paid','Unpaid','Delivery in Progress','Delivered'].forEach(f=>{ %><a class="chip <%= filter===f?'active':'' %>" href="/staff/orders?filter=<%= encodeURIComponent(f) %>"><%= f %></a><% }) %></div>
<table><tr><th>Datum</th><th>Kunde</th><th>Zugewiesen</th><th>Status</th><th>Zahlung</th><th>Lieferung</th><th>Vorbereitet</th><th>Preis</th><th>Aktion</th></tr>
<% orders.forEach(o=>{ %><tr><td><%= new Date(o.created_at).toLocaleString('de-DE') %></td><td><%= o.full_name %><br><small><%= o.email %></small></td><td><%= o.assigned_staff_name||'Nicht zugeteilt' %><% if(isOwner){ %><form method="post" action="/staff/orders/<%= o.id %>/assign" class="stack compact"><select name="assigned_staff_id"><option value="">Keine Zuteilung</option><% staffUsers.forEach(st=>{ %><option value="<%= st.id %>" <%= o.assigned_staff_id===st.id?'selected':'' %>><%= st.full_name %></option><% }) %></select><button>Zuteilen + Mail</button></form><% } %></td><td><%= o.status %></td><td><%= o.payment_status %></td><td><%= o.delivery_status %><% if(o.meeting_status&&o.meeting_status!=='none'){ %><br><small>Termin: <%= o.meeting_status %></small><% } %></td><td><%= o.prepared_count||0 %>/<%= o.item_count||0 %></td><td><small>Original: <%= money(o.original_total_cents||(o.total_cents+(o.credit_used_cents||0))) %></small><br><small>Guthaben: -<%= money(o.credit_used_cents||0) %></small><br><b>Rest: <%= money(o.total_cents) %></b></td><td><% if(o.status==='Placed'){ %><form method="post" action="/staff/orders/<%= o.id %>/update" class="inline"><button name="action" value="accept">Akzeptieren</button><button name="action" value="deny" class="danger">Ablehnen</button></form><% } %><a href="/orders/<%= o.id %>">Details</a><% if(isOwner){ %><form method="post" action="/staff/orders/<%= o.id %>/delete" class="inline" onsubmit="return confirm('Dauerhaft löschen?')"><input type="hidden" name="return_filter" value="<%= filter %>"><label class="tiny"><input type="checkbox" name="restore_stock"> Lager zurück</label><button class="danger">Löschen</button></form><% } %></td></tr><% }) %></table>
<%- include('layout-bottom') %>
