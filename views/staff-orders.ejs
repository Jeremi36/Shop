<%- include('layout-top') %><h1>Bestellungen</h1>
<div class="chips"><% ['Placed','Accepted','Denied','Paid','Unpaid','Delivery in Progress','Delivered'].forEach(f=>{ %><a class="chip <%= filter===f?'active':'' %>" href="/staff/orders?filter=<%= encodeURIComponent(f) %>"><%= f %></a><% }) %></div>
<table>
  <tr><th>Datum</th><th>Kunde</th><th>Zugewiesen</th><th>Status</th><th>Zahlung</th><th>Lieferung</th><th>Vorbereitet</th><th>Gesamt</th><th>Aktion</th></tr>
  <% orders.forEach(o=>{ %>
    <tr>
      <td><%= new Date(o.created_at).toLocaleString('de-DE') %></td>
      <td><%= o.full_name %><br><small><%= o.email %></small></td>
      <td><%= o.assigned_staff_name || '-' %></td>
      <td><%= o.status %></td>
      <td><%= o.payment_status %></td>
      <td><%= o.delivery_status %></td>
      <td><%= o.prepared_count || 0 %>/<%= o.item_count || 0 %></td>
      <td><%= money(o.total_cents) %></td>
      <td>
        <% if (o.status==='Placed') { %>
          <form method="post" action="/staff/orders/<%= o.id %>/update" class="inline"><button name="action" value="accept">Akzeptieren</button><button name="action" value="deny" class="danger">Ablehnen</button></form>
        <% } %>
        <a href="/orders/<%= o.id %>">Details</a>
        <% if (isOwner) { %>
          <form method="post" action="/staff/orders/<%= o.id %>/delete" class="inline" onsubmit="return confirm('Diese Bestellung wirklich dauerhaft löschen?');"><input type="hidden" name="return_filter" value="<%= filter %>"><label class="tiny"><input type="checkbox" name="restore_stock"> Lager zurückbuchen</label><button class="danger">Löschen</button></form>
        <% } %>
      </td>
    </tr>
  <% }) %>
</table><%- include('layout-bottom') %>
