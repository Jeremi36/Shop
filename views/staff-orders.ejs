<%- include('layout-top') %><h1>Bestellungen</h1><table><tr><th>Datum</th><th>Kunde</th><th>Status</th><th>Zahlung</th><th>Lieferung</th><th>Gesamt</th><th></th></tr><% orders.forEach(o=>{ %><tr><td><%= new Date(o.created_at).toLocaleString('de-DE') %></td><td><%= o.full_name %><br><small><%= o.email %></small></td><td><%= o.status %></td><td><%= o.payment_status %></td><td><%= o.delivery_status %></td><td><%= money(o.total_cents) %></td><td><a href="/orders/<%= o.id %>">Bearbeiten</a></td></tr><% }) %></table><%- include('layout-bottom') %>
