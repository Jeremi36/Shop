<%- include('layout-top') %><h1>Produkte bearbeiten</h1>
<section class="panel"><h2>Massen-Discount einstellen</h2><form method="post" action="/staff/products/discount" class="inline"><select name="category_id"><option value="">Alle Kategorien</option><% categories.forEach(c=>{ %><option value="<%= c.id %>" <%= selectedCategory===c.id?'selected':'' %>><%= c.name %></option><% }) %></select><input name="discount_percent" type="number" min="0" max="100" value="0"><button>Rabatt anwenden</button></form></section>
<section class="panel"><h2>Produkt hinzufügen</h2><form method="post" action="/staff/products" enctype="multipart/form-data" class="stack"><input name="name" placeholder="Name" required><textarea name="description" placeholder="Beschreibung"></textarea><select name="category_id"><option value="">Ohne Kategorie</option><% categories.forEach(c=>{ %><option value="<%= c.id %>"><%= c.name %></option><% }) %></select><textarea name="variants" placeholder="Sorten, eine pro Zeile oder mit Komma getrennt&#10;z.B. Cola&#10;Orange&#10;Kirsche"></textarea><input name="price" placeholder="Verkaufspreis z.B. 4,99" required><input name="purchase_price" placeholder="Einkaufspreis z.B. 2,50"><input name="target_profit_percent" type="number" min="0" placeholder="Ziel-Profit %"><input name="stock" type="number" min="0" placeholder="Lagerbestand ohne Sorten" required><input name="discount_percent" type="number" min="0" max="100" value="0"><input name="image" type="file" accept="image/*"><button>Hinzufügen</button></form></section>
<section class="panel"><h2>Kategorien</h2><p><a class="btn" href="/staff/categories">Kategorien verwalten</a></p><div class="chips"><a class="chip <%= !selectedCategory?'active':'' %>" href="/staff/products">Alle</a><% categories.forEach(c=>{ %><a class="chip <%= selectedCategory===c.id?'active':'' %>" href="/staff/products?kategorie=<%= c.id %>"><%= c.name %></a><% }) %></div></section>
<% products.forEach(p=>{ const variants = (p.variants || []).filter(v => v.active).map(v => v.name).join('\n'); %><form method="post" action="/staff/products/<%= p.id %>" enctype="multipart/form-data" class="panel stack"><h2><%= p.name %></h2><input type="hidden" name="old_image_url" value="<%= p.image_url || '' %>"><input name="name" value="<%= p.name %>"><textarea name="description"><%= p.description %></textarea><label>Kategorie<select name="category_id"><option value="">Ohne Kategorie</option><% categories.forEach(c=>{ %><option value="<%= c.id %>" <%= p.category_id===c.id?'selected':'' %>><%= c.name %></option><% }) %></select></label><label>Sorten<textarea name="variants" placeholder="Eine Sorte pro Zeile oder mit Komma getrennt"><%= variants %></textarea></label><input name="price" value="<%= (p.price_cents/100).toFixed(2).replace('.',',') %>" placeholder="Verkaufspreis"><input name="purchase_price" value="<%= ((p.purchase_price_cents||0)/100).toFixed(2).replace('.',',') %>" placeholder="Einkaufspreis"><input name="target_profit_percent" type="number" min="0" value="<%= p.target_profit_percent || 0 %>" placeholder="Ziel-Profit %"><label>Lager ohne Sorten<input name="stock" type="number" min="0" value="<%= p.stock %>"></label><label>Rabatt %<input name="discount_percent" type="number" min="0" max="100" value="<%= p.discount_percent %>"></label><label>Aktiv <input type="checkbox" name="active" <%= p.active?'checked':'' %>></label><input name="image" type="file" accept="image/*"><button>Speichern</button></form><% if ((p.variants||[]).length) { %><section class="panel"><h3>Sorten-Lager für <%= p.name %></h3><form method="post" action="/staff/products/<%= p.id %>/variants" class="stack"><% p.variants.forEach(v=>{ %><div class="inline"><input type="hidden" name="variant_id" value="<%= v.id %>"><input name="variant_name" value="<%= v.name %>"><input name="variant_stock" type="number" min="0" value="<%= v.stock %>"></div><% }) %><div class="inline"><input name="new_variant_name" placeholder="Neue Sorte"><input name="new_variant_stock" type="number" min="0" value="0"></div><button>Sorten speichern</button></form></section><% } %><% }) %><%- include('layout-bottom') %>
