<%- include('layout-top') %>
<h1>Produkte bearbeiten</h1>

<section class="panel sticky-actions">
  <button type="button" class="save-all">Alles speichern</button>
  <span id="saveStatus" class="muted"></span>
</section>

<section class="panel">
  <h2>Massen-Discount einstellen</h2>
  <form method="post" action="/staff/products/discount" class="inline">
    <select name="category_id">
      <option value="">Alle Kategorien</option>
      <% categories.forEach(c=>{ %><option value="<%= c.id %>" <%= selectedCategory===c.id?'selected':'' %>><%= c.name %></option><% }) %>
    </select>
    <input name="discount_percent" type="number" min="0" max="100" value="0">
    <button>Rabatt anwenden</button>
  </form>
</section>

<section class="panel">
  <h2>Profit % für Kategorie ändern</h2>
  <p class="muted">Ändert den Profit % und berechnet den Verkaufspreis aus dem Einkaufspreis neu. Produkte ohne Einkaufspreis bleiben unverändert.</p>
  <form method="post" action="/staff/products/profit-category" class="inline" onsubmit="return confirm('Profit % für alle Artikel in dieser Kategorie ändern? Verkaufspreise werden neu berechnet.');">
    <select name="category_id" required>
      <option value="">Kategorie wählen</option>
      <% categories.forEach(c=>{ %><option value="<%= c.id %>" <%= selectedCategory===c.id?'selected':'' %>><%= c.name %></option><% }) %>
    </select>
    <input name="target_profit_percent" type="number" min="0" step="1" placeholder="Profit % z.B. 60" required>
    <button>Kategorie-Profit anwenden</button>
  </form>
</section>

<section class="panel">
  <h2>Produkt hinzufügen</h2>
  <form method="post" action="/staff/products" enctype="multipart/form-data" class="stack product-price-form">
    <input type="hidden" name="return_to" value="<%= originalUrl || '/staff/products' %>">
    <input name="name" placeholder="Name" required>
    <textarea name="description" placeholder="Beschreibung"></textarea>
    <textarea name="staff_note" placeholder="Interne Staff/Owner-Notiz, z.B. Nachbestell-Link, Lieferant, Hinweise"></textarea>
    <input name="supplier_url" placeholder="Nachbestell-/Händler-Link (nur Staff/Owner)">
    <select name="category_id"><option value="">Allgemein automatisch nutzen</option><% categories.forEach(c=>{ %><option value="<%= c.id %>"><%= c.name %></option><% }) %></select>
    <textarea name="variants" placeholder="Sorten, eine pro Zeile oder mit Komma getrennt&#10;z.B. Cola&#10;Orange&#10;Kirsche"></textarea>
    <label>Verkaufspreis <input class="vp-input" name="price" placeholder="z.B. 4,99" required></label>
    <label>Einkaufspreis <input class="kp-input" name="purchase_price" placeholder="z.B. 2,50"></label>
    <label>Profit % <input class="profit-input" name="target_profit_percent" type="number" min="0" step="1" placeholder="wird automatisch berechnet"></label>
    <input name="stock" type="number" min="0" placeholder="Lagerbestand ohne Sorten" required>
    <label>Rabatt % <input name="discount_percent" type="number" min="0" max="100" value="0"></label>
    <input name="image" type="file" accept="image/*">
    <button>Hinzufügen</button>
  </form>
</section>

<section class="panel">
  <details <%= (sort && sort !== 'created_desc') || (filters && (filters.image || filters.description || filters.supplier || selectedCategory)) ? 'open' : '' %>>
    <summary><b>Filter & Sortierung öffnen/schließen</b></summary>
    <form method="get" action="/staff/products" class="filter-grid">
      <label>Sortieren
        <select name="sort">
          <option value="created_desc" <%= sort==='created_desc'?'selected':'' %>>Neueste zuerst</option>
          <option value="price_asc" <%= sort==='price_asc'?'selected':'' %>>Preis aufsteigend</option>
          <option value="price_desc" <%= sort==='price_desc'?'selected':'' %>>Preis absteigend</option>
          <option value="name_asc" <%= sort==='name_asc'?'selected':'' %>>Name A-Z</option>
          <option value="name_desc" <%= sort==='name_desc'?'selected':'' %>>Name Z-A</option>
          <option value="views_desc" <%= sort==='views_desc'?'selected':'' %>>Meist betrachtet</option>
          <option value="sold_desc" <%= sort==='sold_desc'?'selected':'' %>>Meist verkauft</option>
        </select>
      </label>
      <label>Bild
        <select name="image"><option value="">egal</option><option value="yes" <%= filters.image==='yes'?'selected':'' %>>Bild vorhanden</option><option value="no" <%= filters.image==='no'?'selected':'' %>>Kein Bild vorhanden</option></select>
      </label>
      <label>Beschreibung
        <select name="description"><option value="">egal</option><option value="yes" <%= filters.description==='yes'?'selected':'' %>>Beschreibung vorhanden</option><option value="no" <%= filters.description==='no'?'selected':'' %>>Keine Beschreibung</option></select>
      </label>
      <label>Kategorie
        <select name="kategorie"><option value="">Alle Kategorien</option><% categories.forEach(c=>{ %><option value="<%= c.id %>" <%= selectedCategory===c.id?'selected':'' %>><%= c.name %></option><% }) %></select>
      </label>
      <label>Händler-Link
        <select name="supplier"><option value="">egal</option><option value="yes" <%= filters.supplier==='yes'?'selected':'' %>>Händler-Link vorhanden</option><option value="no" <%= filters.supplier==='no'?'selected':'' %>>Kein Händler-Link</option></select>
      </label>
      <div class="inline"><button>Filter anwenden</button><a class="btn" href="/staff/products">Filter zurücksetzen</a></div>
    </form>
  </details>
  <p class="muted"><%= products.length %> Produkte angezeigt</p>
  <% if (checked) { %><p class="notice">Händlercheck fertig: <b><%= checked %></b> Produkte geprüft. Details stehen direkt bei jedem Produkt unter „Händlerstatus“.</p><% } %>
  <form method="post" action="/staff/products/check-suppliers" onsubmit="return confirm('Alle Händler-Links prüfen? Das kann je nach Anzahl kurz dauern.');"><button>Alle Händler-Links prüfen</button></form>
  <p><a class="btn" href="/staff/categories">Kategorien verwalten</a></p>
</section>

<div class="editor-grid">
<% products.forEach(p=>{ const variantsText = (p.variants || []).filter(v => v.active).map(v => v.name).join('\n'); %>
  <section class="panel product-editor-card" id="produkt-<%= p.id %>">
    <form method="post" action="/staff/products/<%= p.id %>" enctype="multipart/form-data" class="stack product-price-form edit-product-form">
      <input type="hidden" name="return_to" value="<%= originalUrl || '/staff/products' %>">
      <h2><%= p.name %></h2>
      <p class="muted">Produkt-ID: <code><%= p.id %></code></p>
      <p class="muted">Betrachtet: <b><%= p.views_count || 0 %></b> · Gekauft: <b><%= p.sold_count || 0 %></b></p>
      <p class="muted"><b>Lager: <%= p.supplier_status === 'out_of_stock' ? 0 : (p.display_stock ?? p.stock ?? 0) %></b></p>
      <% if (p.supplier_url) { %>
        <p class="muted"><b>Händlerstatus:</b> <%= p.supplier_status || 'unknown' %><% if (p.supplier_status_note) { %> — <%= p.supplier_status_note %><% } %><% if (p.supplier_checked_at) { %> · geprüft: <%= new Date(p.supplier_checked_at).toLocaleString('de-DE') %><% } %></p>
      <% } %>
      <% if (p.image_url) { %><img src="<%= p.image_url %>" alt="<%= p.name %>" class="product-editor-image"><% } else { %><div class="placeholder small">Kein Bild</div><% } %>
      <input type="hidden" name="old_image_url" value="<%= p.image_url || '' %>">
      <input name="name" value="<%= p.name %>">
      <textarea name="description" placeholder="Beschreibung"><%= p.description %></textarea>
      <label>Interne Staff/Owner-Notiz<textarea name="staff_note" placeholder="z.B. Nachbestell-Link, Lieferant, Packhinweise"><%= p.staff_note || '' %></textarea></label>
      <label>Nachbestell-/Händler-Link<input name="supplier_url" value="<%= p.supplier_url || '' %>" placeholder="https://..."></label>
      <% if (p.supplier_url) { %><p class="inline"><a href="<%= p.supplier_url %>" target="_blank" rel="noopener">Händler öffnen</a></p><% } %>
      <label>Kategorie
        <select name="category_id"><option value="">Allgemein automatisch nutzen</option><% categories.forEach(c=>{ %><option value="<%= c.id %>" <%= p.category_id===c.id?'selected':'' %>><%= c.name %></option><% }) %></select>
      </label>
      <label>Sorten<textarea name="variants" placeholder="Eine Sorte pro Zeile oder mit Komma getrennt"><%= variantsText %></textarea></label>
      <label>Verkaufspreis <input class="vp-input" name="price" value="<%= (p.price_cents/100).toFixed(2).replace('.',',') %>" placeholder="Verkaufspreis"></label>
      <label>Einkaufspreis <input class="kp-input" name="purchase_price" value="<%= ((p.purchase_price_cents||0)/100).toFixed(2).replace('.',',') %>" placeholder="Einkaufspreis"></label>
      <label>Profit % <input class="profit-input" name="target_profit_percent" type="number" min="0" step="1" value="<%= p.target_profit_percent || 0 %>" placeholder="Profit %"></label>
      <label>Lager ohne Sorten <input class="product-stock-input" name="stock" type="number" min="0" value="<%= p.stock %>"></label>
      <label>Rabatt % <input name="discount_percent" type="number" min="0" max="100" value="<%= p.discount_percent %>"></label>
      <label>Aktiv <input type="checkbox" name="active" <%= p.active?'checked':'' %>></label>
      <input name="image" type="file" accept="image/*">
      <button>Speichern</button>
    </form>

    <form method="post" action="/staff/products/<%= p.id %>/check-supplier" class="inline" style="margin-top:8px"><input type="hidden" name="return_to" value="<%= originalUrl || '/staff/products' %>"><button>Händlerstatus prüfen</button></form>

    <% if ((p.variants||[]).length) { %>
      <form method="post" action="/staff/products/<%= p.id %>/variants" class="stack bulk-save-form variant-stock-form" style="margin-top:12px">
        <input type="hidden" name="return_to" value="<%= originalUrl || '/staff/products' %>">
        <h3>Sorten-Lager</h3><p class="muted">Wenn Sorten vorhanden sind, wird der Produkt-Lagerbestand automatisch aus der Summe der Sorten berechnet.</p>
        <% p.variants.forEach(v=>{ %><div class="inline"><input type="hidden" name="variant_id" value="<%= v.id %>"><input name="variant_name" value="<%= v.name %>"><input name="variant_stock" type="number" min="0" value="<%= v.stock %>"></div><% }) %>
        <div class="inline"><input name="new_variant_name" placeholder="Neue Sorte"><input name="new_variant_stock" type="number" min="0" value="0"></div>
        <button>Sorten speichern</button>
      </form>
    <% } %>

    <% if (isOwner) { %>
      <form method="post" action="/staff/products/<%= p.id %>/delete" onsubmit="return confirm('Produkt wirklich permanent löschen? Das Produktbild wird auch gelöscht. Alte Bestellungen behalten nur den gespeicherten Produktnamen.');" class="inline" style="margin-top:12px">
        <button class="danger">Produkt permanent löschen</button>
      </form>
    <% } %>
  </section>
<% }) %>
</div>

<section class="panel sticky-actions bottom-actions">
  <button type="button" class="save-all">Alles speichern</button>
  <span class="muted">Speichert alle sichtbaren Produktkarten nacheinander.</span>
</section>

<script>
(function(){
  function parseEuro(v){ return Math.max(0, Number(String(v || '0').replace(',', '.')) || 0); }
  function fmtEuro(v){ return (Math.round(v * 100) / 100).toFixed(2).replace('.', ','); }
  function bind(form){
    const vp = form.querySelector('.vp-input');
    const kp = form.querySelector('.kp-input');
    const pr = form.querySelector('.profit-input');
    if (!vp || !kp || !pr) return;
    function updateProfit(){
      const sell = parseEuro(vp.value);
      const buy = parseEuro(kp.value);
      if (buy <= 0) { pr.value = '0'; return; }
      pr.value = Math.max(0, Math.round(((sell - buy) / buy) * 100));
    }
    function updatePrice(){
      const buy = parseEuro(kp.value);
      const profit = Math.max(0, Number(pr.value) || 0);
      vp.value = fmtEuro(buy * (1 + profit / 100));
    }
    vp.addEventListener('input', updateProfit);
    kp.addEventListener('input', updateProfit);
    pr.addEventListener('input', updatePrice);
    updateProfit();
  }
  document.querySelectorAll('.product-price-form').forEach(bind);

  function syncVariantStock(card){
    const productStock = card.querySelector('.product-stock-input');
    const variantInputs = [...card.querySelectorAll('input[name="variant_stock"]')];
    if (!productStock || !variantInputs.length) return;
    const sum = variantInputs.reduce((total, input) => {
      const n = parseInt(input.value || '0', 10);
      return total + (Number.isFinite(n) && n > 0 ? n : 0);
    }, 0);
    productStock.value = sum;
  }
  document.querySelectorAll('.product-editor-card').forEach(card => {
    syncVariantStock(card);
    card.querySelectorAll('input[name="variant_stock"]').forEach(input => input.addEventListener('input', () => syncVariantStock(card)));
  });

  document.querySelectorAll('.save-all').forEach(btn => btn.addEventListener('click', async () => {
    const status = document.getElementById('saveStatus');
    const forms = [...document.querySelectorAll('.edit-product-form, .bulk-save-form')];
    if (!forms.length) return;
    if (!confirm(forms.length + ' sichtbare Produkte speichern?')) return;
    btn.disabled = true;
    let ok = 0;
    for (const form of forms) {
      status.textContent = 'Speichere ' + (ok + 1) + '/' + forms.length + '...';
      const response = await fetch(form.action, { method: 'POST', body: new FormData(form), headers: { 'Accept': 'application/json', 'X-Requested-With': 'fetch' } });
      if (!response.ok) {
        const txt = await response.text();
        alert('Fehler bei ' + form.action + ': ' + txt);
        btn.disabled = false;
        return;
      }
      ok++;
    }
    status.textContent = 'Alle sichtbaren Produkte gespeichert.';
    btn.disabled = false;
  }));
})();
</script>

<%- include('layout-bottom') %>
