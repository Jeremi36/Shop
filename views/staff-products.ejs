<%- include('layout-top') %>
<h1>Produkte verwalten</h1>
<p><a class="btn" href="/staff/categories">Kategorien verwalten</a></p>
<section class="panel"><h2>Produkt hinzufügen</h2><form method="post" action="/staff/products" enctype="multipart/form-data" class="stack"><input name="name" placeholder="Name" required><textarea name="description" placeholder="Beschreibung"></textarea><select name="category_id"><option value="">Ohne Kategorie</option><% categories.forEach(c=>{ %><option value="<%= c.id %>"><%= c.name %></option><% }) %></select><input name="price" placeholder="Preis z.B. 4,99" required><input name="stock" type="number" min="0" placeholder="Lagerbestand ohne Sorten" required><input name="discount_percent" type="number" min="0" max="100" value="0"><input name="image" type="file" accept="image/*"><button>Hinzufügen</button></form></section>
<% products.forEach(p=>{ %>
  <section class="panel stack">
    <form method="post" action="/staff/products/<%= p.id %>" enctype="multipart/form-data" class="stack"><h2><%= p.name %></h2><input type="hidden" name="old_image_url" value="<%= p.image_url || '' %>"><input name="name" value="<%= p.name %>"><textarea name="description"><%= p.description %></textarea><label>Kategorie<select name="category_id"><option value="">Ohne Kategorie</option><% categories.forEach(c=>{ %><option value="<%= c.id %>" <%= p.category_id===c.id?'selected':'' %>><%= c.name %></option><% }) %></select></label><input name="price" value="<%= (p.price_cents/100).toFixed(2).replace('.',',') %>"><label>Lager ohne Sorten<input name="stock" type="number" min="0" value="<%= p.stock %>"></label><label>Rabatt %<input name="discount_percent" type="number" min="0" max="100" value="<%= p.discount_percent %>"></label><label>Aktiv <input type="checkbox" name="active" <%= p.active?'checked':'' %>></label><input name="image" type="file" accept="image/*"><button>Produkt speichern</button></form>
    <form method="post" action="/staff/products/<%= p.id %>/variants" class="stack">
      <h3>Sorten / Varianten</h3>
      <p class="muted">Beispiele: Cola, Zitrone, Erdbeere, 250g, 500g. Wenn Sorten existieren, müssen Kunden beim Kaufen eine Sorte auswählen.</p>
      <% if (p.variants && p.variants.length) { %>
        <table><tr><th>Sorte</th><th>Lager</th><th></th></tr><% p.variants.forEach(v=>{ %><tr><td><input type="hidden" name="variant_id" value="<%= v.id %>"><input name="variant_name" value="<%= v.name %>"></td><td><input name="variant_stock" type="number" min="0" value="<%= v.stock %>"></td><td><button form="delete-<%= v.id %>" class="secondary">Löschen</button></td></tr><% }) %></table>
      <% } else { %><p>Noch keine Sorten.</p><% } %>
      <h4>Neue Sorte hinzufügen</h4>
      <input name="new_variant_name" placeholder="Neue Sorte z.B. Cola"><input name="new_variant_stock" type="number" min="0" value="0"><button>Sorten speichern</button>
    </form>
    <% if (p.variants) { p.variants.forEach(v=>{ %><form id="delete-<%= v.id %>" method="post" action="/staff/variants/<%= v.id %>/delete"></form><% }) } %>
  </section>
<% }) %>
<%- include('layout-bottom') %>
