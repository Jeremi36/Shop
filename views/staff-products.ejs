<%- include('layout-top') %><h1>Produkte verwalten</h1><section class="panel"><h2>Produkt hinzufügen</h2><form method="post" action="/staff/products" enctype="multipart/form-data" class="stack"><input name="name" placeholder="Name" required><textarea name="description" placeholder="Beschreibung"></textarea><input name="price" placeholder="Preis z.B. 4,99" required><input name="stock" type="number" min="0" placeholder="Lagerbestand" required><input name="discount_percent" type="number" min="0" max="100" value="0"><input name="image" type="file" accept="image/*"><button>Hinzufügen</button></form></section><% products.forEach(p=>{ %><form method="post" action="/staff/products/<%= p.id %>" enctype="multipart/form-data" class="panel stack"><h2><%= p.name %></h2><input type="hidden" name="old_image_url" value="<%= p.image_url || '' %>"><input name="name" value="<%= p.name %>"><textarea name="description"><%= p.description %></textarea><input name="price" value="<%= (p.price_cents/100).toFixed(2).replace('.',',') %>"><label>Lager<input name="stock" type="number" min="0" value="<%= p.stock %>"></label><label>Rabatt %<input name="discount_percent" type="number" min="0" max="100" value="<%= p.discount_percent %>"></label><label>Aktiv <input type="checkbox" name="active" <%= p.active?'checked':'' %>></label><input name="image" type="file" accept="image/*"><button>Speichern</button></form><% }) %><%- include('layout-bottom') %>
