<%- include('layout-top') %>
<h1>Mitarbeiterübersicht <% if(staffActionCount){ %><span class="alert">❗ <%= staffActionCount %> offene Bestellungen</span><% } %></h1>
<div class="grid dashboard-grid">
  <% if(hasPermission('can_manage_orders')){ %><a class="card dashboard-card" href="/staff/orders?filter=Placed"><h2><%= stats.placed %></h2><p>Neue Bestellungen</p></a><a class="card dashboard-card" href="/staff/orders?filter=Accepted"><h2><%= stats.accepted %></h2><p>Angenommene Bestellungen</p></a><a class="card dashboard-card" href="/staff/orders?filter=Delivered"><h2><%= stats.delivered %></h2><p>Abgeschlossene Bestellungen</p></a><% } %>
  <% if(hasPermission('can_view_products')){ %><a class="card dashboard-card" href="/staff/products"><h2><%= stats.products %></h2><p><%= hasPermission('can_edit_products')?'Produkte bearbeiten':'Produkte ansehen' %></p></a><% } %>
  <% if(hasPermission('can_propose_products')){ %><a class="card dashboard-card" href="/staff/product-proposals"><h2><%= stats.product_proposals||0 %></h2><p>Produktvorschläge</p></a><% } %>
  <% if(hasPermission('can_manage_users')||hasPermission('can_ban_users')||hasPermission('can_verify_age')){ %><a class="card dashboard-card" href="/staff/customers"><h2><%= stats.premium %></h2><p>Nutzerverwaltung</p></a><% } %>
  <% if(hasPermission('can_manage_support')){ %><a class="card dashboard-card" href="/staff/support"><h2><%= supportActionCount %></h2><p>Support</p></a><% } %>
  <% if(hasPermission('can_manage_gift_cards')){ %><a class="card dashboard-card" href="/staff/gift-cards"><h2>🎁</h2><p>Gutscheine bestätigen</p></a><% } %>
  <% if(hasPermission('can_manage_discounts')){ %><a class="card dashboard-card" href="/staff/discount-codes"><h2><%= stats.discount_proposals||0 %></h2><p>Rabattcodes</p></a><% } %>
  <% if(hasPermission('can_view_profit')){ %><a class="card dashboard-card" href="/staff/profit"><h2>€</h2><p>Profitübersicht</p></a><% } %>
  <% if(hasPermission('can_change_staff_rank')){ %><a class="card dashboard-card" href="/staff/permissions"><h2>🔐</h2><p>Mitarbeiterrollen</p></a><% } %>
  <% if(isOwner){ %><a class="card dashboard-card" href="/staff/settings"><h2>⚙</h2><p>Owner-Einstellungen</p></a><a class="card dashboard-card" href="/staff/legal"><h2>§</h2><p>Rechtliche Seiten</p></a><a class="card dashboard-card" href="/staff/audit"><h2>PROTOKOLL</h2><p>Audit-Protokoll</p></a><% } %>
</div>
<%- include('layout-bottom') %>
