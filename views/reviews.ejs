<%- include('layout-top') %><h1>Bewertungen</h1><% reviews.forEach(r=>{ %><article class="panel"><h2><%= '★'.repeat(r.rating) %><%= '☆'.repeat(5-r.rating) %></h2><p><%= r.comment || 'Keine Beschreibung.' %></p><% if (r.image_url) { %><img class="review-img" src="<%= r.image_url %>" alt="Bild zur Bewertung"><% } %><small>Von <%= r.full_name %> am <%= new Date(r.created_at).toLocaleDateString('de-DE') %></small></article><% }) %><%- include('layout-bottom') %>
