<% if (user && isCustomer) { %>
<button id="support-launcher" class="support-launcher" type="button" aria-label="Support öffnen">?</button>
<section id="support-panel" class="support-panel" hidden>
  <header class="support-head"><div><b>Premium-Support</b><small id="support-subtitle">Wie können wir helfen?</small></div><button id="support-close" class="support-x" type="button" aria-label="Schließen">×</button></header>
  <div id="support-body" class="support-body"><p class="muted">Support wird geladen …</p></div>
  <form id="support-chat-form" class="support-chat-form" hidden><textarea id="support-chat-input" maxlength="2000" placeholder="Nachricht schreiben …" required></textarea><button>Senden</button></form>
</section>
<script>
(() => {
  const launcher=document.getElementById('support-launcher'), panel=document.getElementById('support-panel'), close=document.getElementById('support-close'), body=document.getElementById('support-body'), chatForm=document.getElementById('support-chat-form'), chatInput=document.getElementById('support-chat-input'), subtitle=document.getElementById('support-subtitle');
  let conversation=null;
  const statusText={open:'Offen',waiting_customer:'Wartet auf deine Antwort',waiting_staff:'Wartet auf einen Mitarbeiter',closed:'Geschlossen'};
  const esc=s=>String(s??'').replace(/[&<>"']/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#039;'}[c]));
  async function api(url,options={}){const r=await fetch(url,{headers:{'Content-Type':'application/json','X-Requested-With':'fetch'},...options});const data=await r.json().catch(()=>({error:'Unbekannter Fehler'}));if(!r.ok)throw new Error(data.error||'Fehler');return data;}
  function isStaffRole(role){return ['owner','co_owner','senior_staff','junior_staff','new_staff'].includes(role);}
  function renderMessages(data){conversation=data.conversation;subtitle.textContent=`Unterhaltung #${conversation.conversation_no}`;body.innerHTML=`<div class="support-conversation-meta"><b>${esc(conversation.subject||conversation.category)}</b><span class="chip">${esc(statusText[conversation.status]||conversation.status)}</span></div><div class="support-messages">${(data.messages||[]).map(m=>`<div class="support-msg ${isStaffRole(m.role)?'staff':''}"><b>${esc(m.full_name||'System')}</b><p>${esc(m.body)}</p><small>${new Date(m.created_at).toLocaleString('de-DE')}</small></div>`).join('')||'<p>Noch keine Nachrichten.</p>'}</div>`;chatForm.hidden=conversation.status==='closed';body.scrollTop=body.scrollHeight;}
  function contactForm(category='Allgemein'){chatForm.hidden=true;subtitle.textContent='Support kontaktieren';body.innerHTML=`<button type="button" class="link-button" id="faq-back">← Häufige Fragen</button><h3>Neue Unterhaltung beginnen</h3><form id="support-create" class="stack"><label>Thema<select name="category"><option>Allgemein</option><option>Altersfreigabe</option><option>Bestellung</option><option>Sperre oder Bestellung anfechten</option><option>Gutschein oder Guthaben</option></select></label><label>Betreff<input name="subject" maxlength="120" required></label><label>Nachricht<textarea name="message" maxlength="2000" required></textarea></label><button>Support anfragen</button></form>`;body.querySelector('[name=category]').value=category;document.getElementById('faq-back').onclick=loadFaq;document.getElementById('support-create').onsubmit=async e=>{e.preventDefault();const fd=new FormData(e.target);try{renderMessages(await api('/api/support/conversations',{method:'POST',body:JSON.stringify(Object.fromEntries(fd))}));}catch(err){alert(err.message);}};}
  async function loadFaq(){conversation=null;chatForm.hidden=true;subtitle.textContent='Wie können wir helfen?';try{const current=await api('/api/support/current');if(current.conversation){renderMessages(current);return;}const data=await api('/api/support/faqs');body.innerHTML=`<h3>Häufige Fragen</h3>${data.faqs.map(f=>`<details class="support-faq"><summary>${esc(f.question)}</summary><p>${esc(f.answer)}</p><div class="support-solved">Konnten wir dein Problem lösen? <button type="button" data-yes>Ja</button><button type="button" class="secondary" data-no data-question="${esc(f.question)}">Nein</button></div></details>`).join('')}<button type="button" id="support-new">Andere Frage stellen</button>`;body.querySelectorAll('[data-yes]').forEach(b=>b.onclick=()=>panel.hidden=true);body.querySelectorAll('[data-no]').forEach(b=>b.onclick=async()=>{b.disabled=true;try{const q=b.dataset.question||'Frage nicht gelöst';renderMessages(await api('/api/support/conversations',{method:'POST',body:JSON.stringify({category:'Häufige Frage nicht gelöst',subject:q,message:`Die Antwort auf „${q}“ konnte mein Problem nicht lösen. Ich brauche Unterstützung.`})}));}catch(err){alert(err.message);b.disabled=false;}});document.getElementById('support-new').onclick=()=>contactForm();}catch(err){body.innerHTML=`<p class="error">${esc(err.message)}</p>`;}}
  launcher.onclick=()=>{panel.hidden=!panel.hidden;if(!panel.hidden)loadFaq();};close.onclick=()=>panel.hidden=true;chatForm.onsubmit=async e=>{e.preventDefault();if(!conversation)return;const message=chatInput.value.trim();if(!message)return;try{const data=await api(`/api/support/conversations/${conversation.id}/messages`,{method:'POST',body:JSON.stringify({message})});chatInput.value='';renderMessages(data);}catch(err){alert(err.message);}};
})();
</script>
<% } %>
