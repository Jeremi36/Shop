<% if (user && isCustomer) { %>
<button id="support-launcher" class="support-launcher" type="button" aria-label="Support öffnen">?</button>
<section id="support-panel" class="support-panel" hidden>
  <header class="support-head"><div><b>Premium Support</b><small id="support-subtitle">Wie können wir helfen?</small></div><button id="support-close" class="support-x" type="button">×</button></header>
  <div id="support-body" class="support-body"><p class="muted">Support wird geladen …</p></div>
  <form id="support-chat-form" class="support-chat-form" hidden><textarea id="support-chat-input" maxlength="2000" placeholder="Nachricht schreiben …" required></textarea><button>Senden</button></form>
</section>
<script>
(() => {
  const launcher=document.getElementById('support-launcher');
  const panel=document.getElementById('support-panel');
  const close=document.getElementById('support-close');
  const body=document.getElementById('support-body');
  const chatForm=document.getElementById('support-chat-form');
  const chatInput=document.getElementById('support-chat-input');
  const subtitle=document.getElementById('support-subtitle');
  let conversation=null;
  const esc=s=>String(s??'').replace(/[&<>"']/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#039;'}[c]));
  async function api(url, options={}) { const r=await fetch(url,{headers:{'Content-Type':'application/json','X-Requested-With':'fetch'},...options}); const data=await r.json().catch(()=>({error:'Unbekannter Fehler'})); if(!r.ok) throw new Error(data.error||'Fehler'); return data; }
  function renderMessages(data){
    conversation=data.conversation;
    subtitle.textContent=`Conversation #${conversation.conversation_no}`;
    body.innerHTML=`<div class="support-conversation-meta"><b>${esc(conversation.subject||conversation.category)}</b><span class="chip">${esc(conversation.status)}</span></div><div class="support-messages">${(data.messages||[]).map(m=>`<div class="support-msg ${m.role==='staff'||m.role==='owner'?'staff':''}"><b>${esc(m.full_name||'System')}</b><p>${esc(m.body)}</p><small>${new Date(m.created_at).toLocaleString('de-DE')}</small></div>`).join('')||'<p>Noch keine Nachrichten.</p>'}</div>`;
    chatForm.hidden=conversation.status==='closed'; body.scrollTop=body.scrollHeight;
  }
  function contactForm(category='Allgemein'){
    chatForm.hidden=true; subtitle.textContent='Support kontaktieren';
    body.innerHTML=`<button type="button" class="link-button" id="faq-back">← Häufige Fragen</button><h3>Conversation erstellen</h3><form id="support-create" class="stack"><label>Thema<select name="category"><option>Allgemein</option><option>Altersverifizierung</option><option>Bestellung</option><option>Sperre/Bestellung anfechten</option><option>Gutschein/Guthaben</option></select></label><label>Betreff<input name="subject" maxlength="120" required></label><label>Nachricht<textarea name="message" maxlength="2000" required></textarea></label><button>Support anfragen</button></form>`;
    body.querySelector('[name=category]').value=category;
    document.getElementById('faq-back').onclick=loadFaq;
    document.getElementById('support-create').onsubmit=async e=>{e.preventDefault(); const fd=new FormData(e.target); try{ const data=await api('/api/support/conversations',{method:'POST',body:JSON.stringify(Object.fromEntries(fd))}); renderMessages(data); }catch(err){alert(err.message);} };
  }
  async function loadFaq(){
    conversation=null; chatForm.hidden=true; subtitle.textContent='Wie können wir helfen?';
    try{
      const current=await api('/api/support/current');
      if(current.conversation){renderMessages(current);return;}
      const data=await api('/api/support/faqs');
      body.innerHTML=`<h3>Häufige Fragen</h3>${data.faqs.map(f=>`<details class="support-faq"><summary>${esc(f.question)}</summary><p>${esc(f.answer)}</p><div class="support-solved">Konnten wir Ihr Problem lösen? <button type="button" data-yes>Ja</button><button type="button" class="secondary" data-no data-question="${esc(f.question)}">Nein</button></div></details>`).join('')}<button type="button" id="support-new">Andere Frage / Support kontaktieren</button>`;
      body.querySelectorAll('[data-yes]').forEach(b=>b.onclick=()=>{panel.hidden=true;});
      body.querySelectorAll('[data-no]').forEach(b=>b.onclick=async()=>{
        b.disabled=true;
        try{
          const question=b.dataset.question||'FAQ nicht gelöst';
          const result=await api('/api/support/conversations',{method:'POST',body:JSON.stringify({category:'FAQ nicht gelöst',subject:question,message:`Die FAQ „${question}“ konnte mein Problem nicht lösen. Ich brauche Unterstützung.`})});
          renderMessages(result);
        }catch(err){alert(err.message);b.disabled=false;}
      });
      document.getElementById('support-new').onclick=()=>contactForm('Allgemein');
    }catch(err){body.innerHTML=`<p class="error">${esc(err.message)}</p>`;}
  }
  launcher.onclick=()=>{panel.hidden=!panel.hidden;if(!panel.hidden)loadFaq();}; close.onclick=()=>panel.hidden=true;
  chatForm.onsubmit=async e=>{e.preventDefault(); if(!conversation)return; const message=chatInput.value.trim(); if(!message)return; try{const data=await api(`/api/support/conversations/${conversation.id}/messages`,{method:'POST',body:JSON.stringify({message})}); chatInput.value=''; renderMessages(data);}catch(err){alert(err.message);}};
})();
</script>
<% } %>
