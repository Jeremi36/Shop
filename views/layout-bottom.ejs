<%- include('support-widget') %>
<script>
(() => {
  const drawer=document.getElementById('site-drawer');
  const backdrop=document.getElementById('drawer-backdrop');
  const open=document.getElementById('menu-open');
  const close=document.getElementById('menu-close');
  if(!drawer||!backdrop||!open||!close)return;
  const setOpen=value=>{
    drawer.classList.toggle('open',value);
    drawer.setAttribute('aria-hidden',String(!value));
    open.setAttribute('aria-expanded',String(value));
    backdrop.hidden=!value;
    document.body.classList.toggle('drawer-is-open',value);
  };
  open.addEventListener('click',()=>setOpen(true));
  close.addEventListener('click',()=>setOpen(false));
  backdrop.addEventListener('click',()=>setOpen(false));
  document.addEventListener('keydown',e=>{if(e.key==='Escape')setOpen(false);});
  drawer.querySelectorAll('a,[data-support-open]').forEach(el=>el.addEventListener('click',()=>setOpen(false)));
})();
</script>
