<%- include('layout-top') %>
<h1>Ränge und Vorteile</h1>
<p class="muted">Dein aktueller Rang ist <b><%= roleLabel(user.role) %></b>. Vorteile bleiben sichtbar, auch wenn ein Rang noch gesperrt ist.</p>

<% if (isCustomer) { const count=Number(stats.order_count||0), spent=Number(stats.spent_cents||0); const unlockedIndex=customerRankOrder.indexOf(user.role); %>
<section class="rank-summary panel">
  <h2>Dein Fortschritt</h2>
  <p><b><%= count %></b> abgeschlossene Bestellungen · <b><%= money(spent) %></b> ausgegeben</p>
  <% if(user.rank_manually_set){ %><p class="notice">Dein Kundenrang wurde manuell festgelegt. Ein Mitarbeiter kann die automatische Einstufung wieder aktivieren.</p><% } %>
</section>
<div class="rank-timeline">
  <% customerRankOrder.forEach((r,index)=>{ const unlocked=index<=unlockedIndex; let progress=''; if(r==='premcustomer') progress=`${Math.min(count,5)}/5 Bestellungen oder ${money(Math.min(spent,5000))}/50,00 €`; if(r==='veteran_customer') progress=`${Math.min(count,10)}/10 Bestellungen oder ${money(Math.min(spent,10000))}/100,00 €`; if(r==='og_customer') progress=`${Math.min(count,25)}/25 Bestellungen und ${money(Math.min(spent,25000))}/250,00 €`; %>
    <article class="rank-step <%= unlocked?'unlocked':'locked' %>">
      <div class="rank-dot"><%= unlocked?'✓':'🔒' %></div>
      <div class="rank-card panel">
        <div class="section-head"><h2><%= roleLabel(r) %></h2><span class="chip <%= unlocked?'active':'' %>"><%= unlocked?'Freigeschaltet':'Gesperrt' %></span></div>
        <% if(progress){ %><p><b>Fortschritt:</b> <%= progress %></p><% } else { %><p><b>Start-Rang</b></p><% } %>
        <ul><% (roleBenefits[r]||[]).forEach(b=>{ %><li><%= b %></li><% }) %></ul>
      </div>
    </article>
  <% }) %>
</div>
<% } else { const currentIndex=staffRankOrder.indexOf(user.role); %>
<div class="rank-timeline staff-ranks">
  <% staffRankOrder.forEach((r,index)=>{ const current=r===user.role; const reached=index<=currentIndex; %>
    <article class="rank-step <%= reached?'unlocked':'locked' %>">
      <div class="rank-dot"><%= current?'★':reached?'✓':'🔒' %></div>
      <div class="rank-card panel">
        <div class="section-head"><h2><%= roleLabel(r) %></h2><span class="chip <%= current?'active':'' %>"><%= current?'Deine Rolle':reached?'Enthalten':'Höhere Rolle' %></span></div>
        <ul><% (roleBenefits[r]||[]).forEach(b=>{ %><li><%= b %></li><% }) %></ul>
      </div>
    </article>
  <% }) %>
</div>
<% } %>
<%- include('layout-bottom') %>
