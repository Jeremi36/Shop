<%- include('layout-top') %>
<section class="hero"><h1>Willkommen im Shop</h1><p>Bestellen, Liefertermin per Nachricht abstimmen und Status live verfolgen.</p></section>
<div class="grid">
<% products.forEach(p => { %>
  <article class="card product">
    <% if (p.image_url) { %><img src="<%= p.image_url %>" alt="<%= p.name %>"><% } else { %><div class="placeholder">Kein Bild</div><% } %>
    <h2><%= p.name %></h2><p><%= p.description %></p>
    <p><% if (p.discount_percent > 0) { %><span class="old"><%= money(p.price_cents) %></span> <b><%= money(discounted(p)) %></b> <span class="sale">-<%= p.discount_percent %>%</span><% } else { %><b><%= money(p.price_cents) %></b><% } %></p>
    <p class="muted">Lager: <%= p.stock %></p>
    <% if (user && user.role === 'customer') { %><form method="post" action="/cart/add/<%= p.id %>" class="inline"><input type="number" name="quantity" min="1" max="<%= p.stock %>" value="1"><button <%= p.stock <= 0 ? 'disabled' : '' %>>In den Warenkorb</button></form><% } else if (!user) { %><a class="btn" href="/login">Einloggen zum Kaufen</a><% } %>
  </article>
<% }) %>
</div>
<%- include('layout-bottom') %>
