<%- include('layout-top') %>
<section class="hero"><h1>Willkommen im Premium Shop</h1><p>Bestellen, Liefertermin per Nachricht abstimmen und Status live verfolgen.</p></section>
<section class="panel"><h2>Kategorien</h2><div class="chips"><a class="chip <%= !selectedCategory ? 'active' : '' %>" href="/">Alle</a><% categories.forEach(c => { %><a class="chip <%= selectedCategory===c.id ? 'active' : '' %>" href="/?kategorie=<%= c.id %>"><%= c.name %></a><% }) %></div></section>
<div class="grid">
<% products.forEach(p => { const variants = variantsByProduct[p.id] || []; %>
  <article class="card product">
    <% if (p.image_url) { %><img src="<%= p.image_url %>" alt="<%= p.name %>"><% } else { %><div class="placeholder">Kein Bild</div><% } %>
    <p class="muted"><%= p.category_name || 'Ohne Kategorie' %></p>
    <h2><%= p.name %></h2><p><%= p.description %></p>
    <% if (variants.length) { %><p class="muted">Sorten: <%= variants.map(v => v.name).join(', ') %></p><% } %>
    <p><% if (p.discount_percent > 0) { %><span class="old"><%= money(p.price_cents) %></span> <b><%= money(discounted(p)) %></b> <span class="sale">-<%= p.discount_percent %>%</span><% } else { %><b><%= money(p.price_cents) %></b><% } %></p>
    <p class="muted">Lager: <%= p.stock %></p>
    <% if (isCustomer) { %><form method="post" action="/cart/add/<%= p.id %>" class="inline"><% if (variants.length) { %><select name="variety" required><option value="">Sorte wählen</option><% variants.forEach(v => { %><option value="<%= v.name %>"><%= v.name %></option><% }) %></select><% } %><input type="number" name="quantity" min="1" max="<%= p.stock %>" value="1"><button <%= p.stock <= 0 ? 'disabled' : '' %>>In den Warenkorb</button></form><% } else if (!user) { %><a class="btn" href="/login">Einloggen zum Kaufen</a><% } %>
  </article>
<% }) %>
</div>
<%- include('layout-bottom') %>
