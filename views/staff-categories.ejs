<%- include('layout-top') %><h1>Kategorien verwalten</h1><section class="panel"><h2>Kategorie hinzufügen</h2><form method="post" action="/staff/categories" class="stack"><input name="name" placeholder="Name" required><textarea name="description" placeholder="Beschreibung optional"></textarea><label>Altersmarkierung<select name="age_level"><option value="0">0</option><option value="16">16+</option><option value="18">18+</option></select></label><button>Hinzufügen</button></form></section><% categories.forEach(c=>{ %><form method="post" action="/staff/categories/<%= c.id %>" class="panel stack"><input name="name" value="<%= c.name %>" required><textarea name="description"><%= c.description %></textarea><label>Altersmarkierung<select name="age_level"><option value="0" <%= (c.age_level||0)===0?'selected':'' %>>0</option><option value="16" <%= c.age_level===16?'selected':'' %>>16+</option><option value="18" <%= c.age_level===18?'selected':'' %>>18+</option></select></label><label>Aktiv <input type="checkbox" name="active" <%= c.active?'checked':'' %>></label><button>Speichern</button></form><% }) %><%- include('layout-bottom') %>
