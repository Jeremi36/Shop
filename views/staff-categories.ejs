<%- include('layout-top') %><h1>Kategorien verwalten</h1><section class="panel"><h2>Kategorie hinzufügen</h2><form method="post" action="/staff/categories" class="stack"><input name="name" placeholder="Name" required><textarea name="description" placeholder="Beschreibung optional"></textarea><button>Hinzufügen</button></form></section><% categories.forEach(c=>{ %><form method="post" action="/staff/categories/<%= c.id %>" class="panel stack"><input name="name" value="<%= c.name %>" required><textarea name="description"><%= c.description %></textarea><label>Aktiv <input type="checkbox" name="active" <%= c.active?'checked':'' %>></label><button>Speichern</button></form><% }) %><%- include('layout-bottom') %>
