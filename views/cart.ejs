<%- include('layout-top') %>
<div class="section-head"><div><span class="eyebrow">Dein Einkauf</span><h1>Warenkorb</h1><p class="muted"><%= items.length %> Position<%= items.length===1?'':'en' %> · aktuelle Summe <%= money(total||0) %></p></div><a class="btn secondary" href="/">Weiter einkaufen</a></div>
<% if(!items.length){ %>
  <section class="panel empty-state"><span>🛒</span><h2>Dein Warenkorb ist leer</h2><p>Entdecke unser Sortiment und füge deine gewünschten Produkte hinzu.</p><a class="btn" href="/">Produkte ansehen</a></section>
<% } else { %>
<div class="two-col" style="grid-template-columns:minmax(0,1.55fr) minmax(320px,.65fr);align-items:start">
  <div>
    <section class="panel">
      <h2>Deine Produkte</h2>
      <div class="table-wrap"><table><thead><tr><th>Produkt</th><th>Sorte</th><th>Menge</th><th>Einzelpreis</th><th>Summe</th></tr></thead><tbody><% items.forEach(i=>{ %><tr><td><strong><%= i.name %></strong></td><td><%= i.variant_name||'–' %></td><td><form method="post" action="/cart/update/<%= i.cart_id %>" class="inline compact"><input type="number" name="quantity" min="0" max="<%= i.stock %>" value="<%= i.quantity %>" aria-label="Menge von <%= i.name %>"><button class="secondary">Ändern</button></form><small>0 entfernt den Artikel</small></td><td><%= money(discounted(i)) %></td><td><strong><%= money(discounted(i)*i.quantity) %></strong></td></tr><% }) %></tbody></table></div>
    </section>

    <section class="panel">
      <h2>Rabattcode</h2>
      <% if(couponError){ %><p class="error"><%= couponError %></p><% } %><% if(couponSuccess){ %><p class="success"><%= couponSuccess %></p><% } %>
      <% if(couponResult&&couponResult.valid){ %><div class="section-head"><p><b>Aktiver Code:</b> <%= couponResult.code %><br><span class="positive">Du sparst <%= money(couponResult.discountCents) %></span></p><form method="post" action="/cart/coupon/remove"><button class="secondary">Entfernen</button></form></div><% } else { %><form method="post" action="/cart/coupon" class="inline"><input name="code" placeholder="Rabattcode eingeben"><button>Anwenden</button></form><% } %>
    </section>

    <div class="notice"><b>Übergabe und Altersprüfung</b><br>Treffpunkt und Zeitpunkt werden nach der Bestellung abgestimmt. Bei altersbeschränkten Produkten kann das Alter bei der Übergabe erneut geprüft werden. Gesetzliche Verbraucherrechte bleiben unberührt.</div>
  </div>

  <aside>
    <section class="panel order-totals" style="max-width:none;margin:0 0 1rem">
      <h2>Zusammenfassung</h2>
      <div class="order-total-line"><span>Zwischensumme</span><strong><%= money(subtotal) %></strong></div>
      <% if(couponResult&&couponResult.valid){ %><div class="order-total-line"><span>Rabatt</span><strong class="positive">−<%= money(couponResult.discountCents) %></strong></div><% } %>
      <div class="order-total-line grand"><span>Vor Guthaben</span><strong><%= money(total) %></strong></div>
    </section>

    <form method="post" action="/orders/place" class="panel stack" id="checkout-form">
      <h2>Bestellung abschließen</h2>
      <label>Zahlungsart<select name="payment_method" id="payment-method"><option value="Vorauszahlung">Vorauszahlung nach Absprache</option><option value="PayPal" <%= paypalConfigured?'':'disabled' %>>PayPal<%= paypalConfigured?'':' – derzeit nicht eingerichtet' %></option><% if(user.role==='veteran_customer'||user.role==='og_customer'){ %><option value="Bei Lieferung">Bei Lieferung</option><% } %></select></label>
      <div class="payment-guidance" id="paypal-cart-hint" hidden><b>PayPal-Hinweis</b><p>Nach der Bestellung öffnest du eine eigene Zahlungsübersicht. Prüfe dort Empfänger, Betrag und Bestellnummer. Die Zahlung wird erst nach manueller Kontrolle als bezahlt markiert.</p></div>
      <label>Guthaben verwenden <small>Verfügbar: <%= money(availableCredit) %></small><input name="credit_to_use" type="number" min="0" max="<%= Math.min(availableCredit,total)/100 %>" step="0.01" value="0"></label>
      <p class="muted">Deckt dein Guthaben den vollständigen Restbetrag, gilt die Bestellung automatisch als bezahlt.</p>
      <label class="legal-check"><input type="checkbox" name="legal_accept" required> <span>Ich habe die <a href="/legal/agb" target="_blank">AGB</a>, die <a href="/legal/widerruf" target="_blank">Widerrufsbelehrung</a> sowie die Liefer-, Übergabe- und Zahlungsinformationen gelesen und gebe eine zahlungspflichtige Bestellung ab.</span></label>
      <button class="btn-large">Zahlungspflichtig bestellen</button>
      <small>Der endgültige Zahlbetrag wird vor dem Absenden durch Guthaben und Rabatt berechnet.</small>
    </form>
  </aside>
</div>
<script>
(() => { const select=document.getElementById('payment-method'),hint=document.getElementById('paypal-cart-hint');if(!select||!hint)return;const sync=()=>hint.hidden=select.value!=='PayPal';select.addEventListener('change',sync);sync();})();
</script>
<% } %>
<%- include('layout-bottom') %>
