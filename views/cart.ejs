<%- include('layout-top') %><h1>Warenkorb</h1>
<% if (!items.length) { %><p>Dein Warenkorb ist leer.</p><% } else { %>
<table><tr><th>Produkt</th><th>Sorte</th><th>Menge</th><th>Preis</th><th>Summe</th></tr><% items.forEach(i=>{ %><tr><td><%= i.name %></td><td><%= i.variant_name||'-' %></td><td><form method="post" action="/cart/update/<%= i.cart_id %>" class="inline"><input type="number" name="quantity" min="0" max="<%= i.stock %>" value="<%= i.quantity %>"><button>Ändern</button></form></td><td><%= money(discounted(i)) %></td><td><%= money(discounted(i)*i.quantity) %></td></tr><% }) %></table>
<section class="panel"><h2>Rabattcode</h2><% if(couponError){ %><p class="error"><%= couponError %></p><% } %><% if(couponSuccess){ %><p class="success"><%= couponSuccess %></p><% } %><% if(couponResult&&couponResult.valid){ %><p><b>Aktiver Code:</b> <%= couponResult.code %> · Rabatt: <%= money(couponResult.discountCents) %></p><form method="post" action="/cart/coupon/remove"><button class="secondary">Rabattcode entfernen</button></form><% } else { %><form method="post" action="/cart/coupon" class="inline"><input name="code" placeholder="Rabattcode eingeben"><button>Anwenden</button></form><% } %></section>
<div class="notice"><b>Wichtige Bestellhinweise:</b><br>Die lokale Übergabe wird über Treffpunkt und Termin abgestimmt. Bei altersbeschränkten Kategorien ist eine Staff-Freigabe erforderlich und das Alter kann bei der Übergabe erneut geprüft werden. Gesetzliche Verbraucherrechte werden durch diese Anzeige nicht ausgeschlossen.</div>
<h2>Zwischensumme: <%= money(subtotal) %></h2><% if(couponResult&&couponResult.valid){ %><h2>Rabatt: -<%= money(couponResult.discountCents) %></h2><% } %><h2>Vor Guthaben: <%= money(total) %></h2>
<form method="post" action="/orders/place" class="panel stack">
<label>Zahlungsart<select name="payment_method"><option>Vorauszahlung</option><% if(user.role==='premcustomer'||user.premium){ %><option>Bei Lieferung</option><% } %></select></label>
<label>Guthaben verwenden (verfügbar: <%= money(availableCredit) %>)<input name="credit_to_use" type="number" min="0" max="<%= Math.min(availableCredit,total)/100 %>" step="0.01" value="0"></label>
<p class="muted">Deckt das Guthaben den gesamten Betrag, wird die Bestellung automatisch auf Paid gesetzt.</p>
<label class="legal-check"><input type="checkbox" name="legal_accept" required> Ich habe <a href="/legal/agb" target="_blank">AGB</a>, <a href="/legal/widerruf" target="_blank">Widerrufsbelehrung</a>, Liefer-/Übergabe- und Zahlungsinformationen gelesen und bestätige die zahlungspflichtige Bestellung.</label>
<button>Zahlungspflichtig bestellen</button></form>
<% } %><%- include('layout-bottom') %>
