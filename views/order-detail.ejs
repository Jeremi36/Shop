<%- include('layout-top') %>
<h1>Bestellung</h1>

<div class="panel">
  <p><b>Kunde:</b> <%= order.full_name %> · <%= order.email %></p>
  <p><b>Zugewiesen:</b> <%= order.assigned_staff_name || 'Automatisch / keiner' %></p>
  <p><b>Status:</b> <%= order.status %> · <b>Zahlung:</b> <%= order.payment_status %> · <b>Lieferung:</b> <%= order.delivery_status %></p>
  <p><b>Zahlungsart:</b> <%= order.payment_method %></p>
  <pre><%= order.address_snapshot %></pre>
</div>

<table>
  <tr>
    <% if (isStaff) { %><th>Vorbereitet</th><% } %>
    <th>Produkt</th>
    <th>Sorte</th>
    <th>Menge</th>
    <th>Preis pro Item</th>
    <th>Summe</th>
    <% if (isStaff) { %><th>Interne Notiz</th><% } %>
  </tr>
  <% items.forEach(i => { const unit = Math.round(i.unit_price_cents*(100-i.discount_percent)/100); const note = i.current_staff_note || i.staff_note_snapshot || ''; %>
    <tr>
      <% if (isStaff) { %>
        <td>
          <form method="post" action="/staff/order-items/<%= i.id %>/prepared" class="inline">
            <label class="tiny"><input type="checkbox" name="prepared" <%= i.prepared ? 'checked' : '' %> onchange="this.form.submit()"> fertig</label>
          </form>
        </td>
      <% } %>
      <td><%= i.product_name %> <% if (i.discount_percent) { %><span class="sale">-<%= i.discount_percent %>%</span><% } %></td>
      <td><%= i.variant_name || i.variety || '-' %></td>
      <td><%= i.quantity %></td>
      <td><%= money(unit) %></td>
      <td><%= money(unit*i.quantity) %></td>
      <% if (isStaff) { %>
        <td><% if (note) { %><pre class="staff-note"><%= note %></pre><% } else { %><span class="muted">Keine Notiz</span><% } %></td>
      <% } %>
    </tr>
  <% }) %>
</table>

<% if (order.discount_cents && order.discount_cents > 0) { %>
  <p class="sale">Rabattcode <%= order.discount_code || '' %>: -<%= money(order.discount_cents) %></p>
<% } %>
<h2>Gesamt: <%= money(order.total_cents) %></h2>

<% if (isStaff) { %>
  <form method="post" action="/staff/orders/<%= order.id %>/update" class="panel three">
    <% if (order.status==='Placed') { %>
      <button name="action" value="accept">Akzeptieren</button>
      <button name="action" value="deny" class="danger">Ablehnen</button>
    <% } else { %>
      <label>Bestellstatus
        <select name="status"><% ['Accepted','Denied'].forEach(s=>{ %><option <%= order.status===s?'selected':'' %>><%= s %></option><% }) %></select>
      </label>
      <% if (order.status==='Accepted') { %>
        <label>Zahlung
          <select name="payment_status" <%= order.payment_method==='Bei Lieferung'?'disabled':'' %>><% (order.payment_method==='Bei Lieferung' ? ['Pay on delivery'] : ['Unpaid','Paid']).forEach(s=>{ %><option <%= order.payment_status===s?'selected':'' %>><%= s %></option><% }) %></select>
        </label>
        <label>Lieferung
          <select name="delivery_status"><% ['Delivery in Progress','Delivered'].forEach(s=>{ %><option <%= order.delivery_status===s?'selected':'' %>><%= s %></option><% }) %></select>
        </label>
      <% } %>
      <button>Aktualisieren</button>
    <% } %>
  </form>
<% } %>

<section class="panel">
  <h2>Nachrichten zur Liefertermin-Abstimmung</h2>
  <div class="chat"><% messages.forEach(m => { %><div class="msg <%= m.role %>"><b><%= m.full_name %> (<%= roleLabel(m.role) %>):</b> <%= m.body %><small><%= new Date(m.created_at).toLocaleString('de-DE') %></small></div><% }) %></div>
  <form method="post" action="/orders/<%= order.id %>/message" class="stack"><textarea name="body" required placeholder="Nachricht schreiben..."></textarea><button>Senden</button></form>
</section>

<form method="post" action="/orders/<%= order.id %>/archive"><button class="secondary">Konversation archivieren</button></form>

<% if (isOwner) { %>
  <form method="post" action="/staff/orders/<%= order.id %>/delete" class="panel" onsubmit="return confirm('Diese Bestellung wirklich dauerhaft löschen?');">
    <input type="hidden" name="return_filter" value="<%= order.delivery_status === 'Delivered' ? 'Delivered' : order.status %>">
    <label><input type="checkbox" name="restore_stock"> Lager zurückbuchen, falls nicht geliefert</label>
    <button class="danger">Bestellung dauerhaft löschen</button>
  </form>
<% } %>

<% if (isCustomer && order.delivery_status === 'Delivered') { %>
  <section class="panel">
    <h2>Bewertung</h2>
    <form method="post" action="/orders/<%= order.id %>/review" class="stack">
      <label>Sterne<select name="rating"><% [1,2,3,4,5].forEach(r=>{ %><option value="<%= r %>" <%= review && review.rating===r?'selected':'' %>><%= r %> Sterne</option><% }) %></select></label>
      <textarea name="comment" placeholder="Kommentar optional"><%= review ? review.comment : '' %></textarea>
      <button>Bewertung speichern</button>
    </form>
  </section>
<% } %>
<%- include('layout-bottom') %>
