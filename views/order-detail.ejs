<%- include('layout-top') %>
<h1>Bestellung</h1>
<section class="panel">
  <% if (isStaff) { %>
    <p><b>Kunde:</b> <%= order.full_name %><% if(hasPermission('can_view_customer_email')){ %> · <%= order.email %><% } %></p>
  <% } %>
  <p><b>Bestellnummer:</b> <%= orderReference(order) %></p>
  <p><b>Zugewiesen:</b> <%= order.assigned_staff_name || 'Noch nicht zugeteilt' %></p>
  <p><b>Bestellung:</b> <%= statusDe('status',order.status) %> · <b>Zahlung:</b> <%= statusDe('payment_status',order.payment_status) %> · <b>Übergabe:</b> <%= statusDe('delivery_status',order.delivery_status) %></p>
  <p><b>Zahlungsart:</b> <%= order.payment_method %></p>
  <% if (order.meeting_location || order.meeting_at || order.meeting_note) { %><div class="notice"><b>Treffpunktstatus:</b> <%= ({none:'Noch offen',proposed:'Vorgeschlagen',confirmed:'Bestätigt',rejected:'Abgelehnt',customer_proposed:'Gegenvorschlag des Kunden'}[order.meeting_status]||order.meeting_status) %><br><b>Ort:</b> <%= order.meeting_location || '–' %><br><b>Zeit:</b> <%= order.meeting_at ? new Date(order.meeting_at).toLocaleString('de-DE') : '–' %><br><b>Hinweis:</b> <%= order.meeting_note || '–' %></div><% } %>
  <% if (isStaff && hasPermission('can_view_customer_email')) { %><pre><%= order.address_snapshot %></pre><% } %>
</section>

<section class="panel"><h2>Bestellverlauf</h2><div class="timeline"><% (events||[]).forEach(e=>{ const eventNames={placed:'Bestellung aufgegeben',message:'Nachricht geschrieben',status_update:'Status geändert',meeting_proposed:'Treffpunkt vorgeschlagen',meeting_confirmed:'Treffpunkt bestätigt',meeting_rejected:'Treffpunkt abgelehnt',meeting_counter:'Gegenvorschlag gesendet',review:'Bewertung gespeichert',assigned:'Zuteilung geändert',paypal_paid:'PayPal-Zahlung bestätigt'}; %><div class="timeline-item"><b><%= eventNames[e.event_type]||e.event_type %></b> · <%= new Date(e.created_at).toLocaleString('de-DE') %><br><small><%= e.full_name || 'System' %></small><% if(e.note){ %><p><%= e.note %></p><% } %></div><% }) %></div></section>

<table><tr><% if(isStaff&&hasPermission('can_edit_orders')){ %><th>Vorbereitet</th><% } %><th>Produkt</th><th>Sorte</th><th>Menge</th><th>Einzelpreis</th><th>Summe</th><% if(isStaff&&hasPermission('can_view_staff_notes')){ %><th>Interne Notiz</th><% } %><% if(isStaff&&hasPermission('can_edit_orders')){ %><th>Bearbeiten</th><% } %></tr>
<% items.forEach(i=>{ const unit=Math.round(i.unit_price_cents*(100-i.discount_percent)/100); const note=i.current_staff_note||i.staff_note_snapshot||''; %><tr>
  <% if(isStaff&&hasPermission('can_edit_orders')){ %><td><form method="post" action="/staff/order-items/<%= i.id %>/prepared"><label class="tiny"><input type="checkbox" name="prepared" <%= i.prepared?'checked':'' %> onchange="this.form.submit()"> fertig</label></form></td><% } %>
  <td><%= i.product_name %> <% if(i.discount_percent){ %><span class="sale">−<%= i.discount_percent %>%</span><% } %></td><td><%= i.variant_name||i.variety||'–' %></td><td><%= i.quantity %></td><td><%= money(unit) %></td><td><%= money(unit*i.quantity) %></td>
  <% if(isStaff&&hasPermission('can_view_staff_notes')){ %><td><% if(note){ %><pre class="staff-note"><%= note %></pre><% } else { %><span class="muted">Keine Notiz</span><% } %></td><% } %>
  <% if(isStaff&&hasPermission('can_edit_orders')){ %><td><% if(order.delivery_status!=='Delivered'){ %><form method="post" action="/staff/order-items/<%= i.id %>/update" class="stack compact"><input name="quantity" type="number" min="1" value="<%= i.quantity %>"><input name="unit_price" value="<%= (i.unit_price_cents/100).toFixed(2).replace('.',',') %>"><button>Ändern</button></form><form method="post" action="/staff/order-items/<%= i.id %>/delete" onsubmit="return confirm('Artikel entfernen?')"><button class="danger">Entfernen</button></form><% } else { %><span class="muted">Abgeschlossen</span><% } %></td><% } %>
</tr><% }) %></table>

<section class="panel order-totals">
  <% if(order.discount_cents>0){ %><p>Rabattcode <%= order.discount_code||'' %>: <b>−<%= money(order.discount_cents) %></b></p><% } %>
  <p>Ursprünglicher Preis: <b><%= money(order.original_total_cents || (order.total_cents + (order.credit_used_cents||0))) %></b></p>
  <p>Verwendetes Guthaben: <b>−<%= money(order.credit_used_cents||0) %></b></p>
  <% if(order.cashback_awarded_cents>0){ %><p>OG-Cashback: <b class="positive">+<%= money(order.cashback_awarded_cents) %></b></p><% } %>
  <h2>Restpreis: <%= money(order.total_cents) %></h2>
  <% if(order.credit_refunded_at){ %><p class="success">Das verwendete Guthaben wurde zurückerstattet.</p><% } %>
</section>

<% if(order.payment_method==='PayPal'){ %>
<section class="panel">
  <h2>PayPal-Zahlung</h2>
  <p><b>Bestellnummer:</b> <%= orderReference(order) %></p>
  <p><b>Zu zahlen:</b> <%= money(order.total_cents) %></p>
  <% if(order.payment_status==='Paid'){ %>
    <p class="success">Der PayPal-Zahlungseingang wurde vom Owner bestätigt.</p>
  <% } else if(isCustomer && paypalPaymentUrl){ %>
    <p>Die Zahlung wird nicht automatisch als bezahlt erkannt. Nach dem Senden prüft der Owner den Zahlungseingang manuell.</p>
    <a class="btn" href="/orders/<%= order.id %>/paypal">PayPal-Zahlungsseite öffnen</a>
  <% } else if(isStaff){ %>
    <p class="notice">PayPal-Zahlung noch nicht bestätigt.</p>
    <% if(isOwner){ %><form method="post" action="/staff/orders/<%= order.id %>/paypal-paid" onsubmit="return confirm('Hast du den vollständigen Betrag wirklich erhalten?')"><button>PayPal-Zahlung als erhalten markieren</button></form><% } %>
  <% } %>
</section>
<% } %>

<% if(isCustomer && order.meeting_status==='proposed'){ %><section class="panel"><h2>Treffpunkt bestätigen</h2><form method="post" action="/orders/<%= order.id %>/meeting-response" class="inline"><button name="action" value="confirm">Bestätigen</button><button name="action" value="reject" class="danger">Ablehnen</button></form><details><summary>Gegenvorschlag machen</summary><form method="post" action="/orders/<%= order.id %>/meeting-response" class="stack"><input type="hidden" name="action" value="counter"><input name="meeting_location" placeholder="Anderer Treffpunkt" required><input name="meeting_at" type="datetime-local" required><textarea name="note" placeholder="Nachricht"></textarea><button>Gegenvorschlag senden</button></form></details></section><% } %>

<% if(isStaff&&hasPermission('can_manage_orders')){ %>
<section class="panel"><h2>Bestellung bearbeiten</h2>
  <% if(order.status==='Placed'&&hasPermission('can_accept_orders')){ %><form method="post" action="/staff/orders/<%= order.id %>/update" class="inline"><button name="action" value="accept">Annehmen</button><% if(hasPermission('can_edit_orders')){ %><button name="action" value="deny" class="danger">Ablehnen</button><% } %></form><% } %>
  <% if(order.status==='Accepted'){ %><form method="post" action="/staff/orders/<%= order.id %>/update" class="three">
    <% if(hasPermission('can_edit_orders')){ %><label>Bestellstatus<select name="status"><option value="Accepted" <%= order.status==='Accepted'?'selected':'' %>>Angenommen</option><option value="Denied">Abgelehnt</option></select></label><% } %>
    <% if(hasPermission('can_mark_paid')&&order.payment_method!=='Bei Lieferung'&&order.payment_method!=='Guthaben'&&(order.payment_method!=='PayPal'||isOwner)){ %><label>Zahlung<select name="payment_status"><option value="Unpaid" <%= order.payment_status==='Unpaid'?'selected':'' %>>Nicht bezahlt</option><option value="Paid" <%= order.payment_status==='Paid'?'selected':'' %>>Bezahlt</option></select></label><% } %>
    <% if(hasPermission('can_mark_delivered')){ %><label>Übergabe<select name="delivery_status"><option value="Delivery in Progress" <%= order.delivery_status==='Delivery in Progress'?'selected':'' %>>In Bearbeitung</option><option value="Delivered" <%= order.delivery_status==='Delivered'?'selected':'' %>>Übergeben</option></select></label><% } %>
    <button>Änderungen speichern</button>
  </form><% } %>
</section>
<% } %>

<% if(isStaff&&hasPermission('can_manage_meetings')){ %><section class="panel"><h2>Treffpunkt und Uhrzeit</h2><form method="post" action="/staff/orders/<%= order.id %>/meeting" class="stack"><input name="meeting_location" placeholder="z. B. Bahnhof Amberg" value="<%= order.meeting_location||'' %>" required><input name="meeting_at" type="datetime-local" value="<%= order.meeting_at?new Date(order.meeting_at).toISOString().slice(0,16):'' %>" required><textarea name="meeting_note" placeholder="Zusätzliche Nachricht"><%= order.meeting_note||'' %></textarea><button>Vorschlag senden und Kunden informieren</button></form><% if(order.meeting_status==='customer_proposed'){ %><form method="post" action="/staff/orders/<%= order.id %>/meeting-confirm"><button>Gegenvorschlag bestätigen</button></form><% } %></section><% } %>

<% if(isStaff&&hasPermission('can_edit_orders')&&order.delivery_status!=='Delivered'){ %><section class="panel"><h2>Artikel hinzufügen</h2><form method="post" action="/staff/orders/<%= order.id %>/add-item" class="inline"><select name="product_id"><% productsForOrder.forEach(p=>{ %><option value="<%= p.id %>"><%= p.name %> · <%= money(p.price_cents) %></option><% }) %></select><input name="quantity" type="number" min="1" value="1"><button>Hinzufügen</button></form></section><% } %>

<% if(isOwner){ %><section class="panel"><h2>Interne Zusatzkosten</h2><form method="post" action="/staff/orders/<%= order.id %>/costs" class="inline"><input name="extra_cost" value="<%= ((order.extra_cost_cents||0)/100).toFixed(2).replace('.',',') %>"><input name="extra_cost_note" value="<%= order.extra_cost_note||'' %>" placeholder="Grund"><button>Speichern</button></form></section><% } %>

<section class="panel"><h2>Nachrichten zur Bestellung</h2><div class="chat"><% messages.forEach(m=>{ %><div class="msg <%= isStaff&&['owner','co_owner','senior_staff','junior_staff','new_staff'].includes(m.role)?'staff':'' %>"><b><%= m.full_name %> (<%= roleLabel(m.role) %>):</b> <%= m.body %><small><%= new Date(m.created_at).toLocaleString('de-DE') %></small></div><% }) %></div><form method="post" action="/orders/<%= order.id %>/message" class="stack"><textarea name="body" required placeholder="Nachricht schreiben"></textarea><button>Senden</button></form></section>
<form method="post" action="/orders/<%= order.id %>/archive"><button class="secondary">Bestellung archivieren</button></form>

<% if(isOwner){ %><form method="post" action="/staff/orders/<%= order.id %>/delete" class="panel" onsubmit="return confirm('Bestellung dauerhaft löschen?')"><input type="hidden" name="return_filter" value="<%= order.delivery_status==='Delivered'?'Delivered':order.status %>"><label><input type="checkbox" name="restore_stock"> Lager zurückbuchen</label><button class="danger">Bestellung dauerhaft löschen</button></form><% } %>

<% if(isCustomer&&order.delivery_status==='Delivered'){ %><section class="panel"><h2>Bewertung</h2><form method="post" action="/orders/<%= order.id %>/review" class="stack" enctype="multipart/form-data"><select name="rating"><% [5,4,3,2,1].forEach(n=>{ %><option value="<%= n %>" <%= review&&review.rating===n?'selected':'' %>><%= n %> Sterne</option><% }) %></select><textarea name="comment" placeholder="Deine Erfahrung"><%= review?review.comment:'' %></textarea><label>Optional ein Bild anhängen<input type="file" name="image" accept="image/png,image/jpeg,image/webp,image/gif"></label><% if(review&&review.image_url){ %><img class="review-img" src="<%= review.image_url %>" alt="Bild zur Bewertung"><% } %><button>Bewertung speichern</button></form></section><% } %>
<%- include('layout-bottom') %>
