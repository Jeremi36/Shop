<%- include('layout-top') %>
<h1>Bestellung</h1><div class="panel"><p><b>Kunde:</b> <%= order.full_name %> · <%= order.email %></p><p><b>Status:</b> <%= order.status %> · <b>Zahlung:</b> <%= order.payment_status %> · <b>Lieferung:</b> <%= order.delivery_status %></p><p><b>Zahlungsart:</b> <%= order.payment_method %></p><pre><%= order.address_snapshot %></pre></div>
<table><tr><th>Produkt</th><th>Menge</th><th>Einzelpreis</th></tr><% items.forEach(i => { %><tr><td><%= i.product_name %> <% if (i.discount_percent) { %><span class="sale">-<%= i.discount_percent %>%</span><% } %></td><td><%= i.quantity %></td><td><%= money(Math.round(i.unit_price_cents*(100-i.discount_percent)/100)) %></td></tr><% }) %></table><h2>Gesamt: <%= money(order.total_cents) %></h2>
<% if (user.role === 'staff') { %><form method="post" action="/staff/orders/<%= order.id %>/update" class="panel three"><label>Bestellstatus<select name="status"><% ['Placed','Accepted','Denied'].forEach(s=>{ %><option <%= order.status===s?'selected':'' %>><%= s %></option><% }) %></select></label><label>Zahlung<select name="payment_status"><% ['Unpaid','Paid'].forEach(s=>{ %><option <%= order.payment_status===s?'selected':'' %>><%= s %></option><% }) %></select></label><label>Lieferung<select name="delivery_status"><% ['Delivery in Progress','Delivered'].forEach(s=>{ %><option <%= order.delivery_status===s?'selected':'' %>><%= s %></option><% }) %></select></label><button>Aktualisieren</button></form><% } %>
<section class="panel"><h2>Nachrichten zur Liefertermin-Abstimmung</h2><div class="chat"><% messages.forEach(m => { %><div class="msg <%= m.role %>"><b><%= m.full_name %>:</b> <%= m.body %><small><%= new Date(m.created_at).toLocaleString('de-DE') %></small></div><% }) %></div><form method="post" action="/orders/<%= order.id %>/message" class="stack"><textarea name="body" required placeholder="Nachricht schreiben..."></textarea><button>Senden</button></form></section>
<form method="post" action="/orders/<%= order.id %>/archive"><button class="secondary">Konversation archivieren</button></form>
<% if (user.role === 'customer' && order.delivery_status === 'Delivered') { %><section class="panel"><h2>Bewertung</h2><form method="post" action="/orders/<%= order.id %>/review" class="stack"><label>Sterne<select name="rating"><% [1,2,3,4,5].forEach(r=>{ %><option value="<%= r %>" <%= review && review.rating===r?'selected':'' %>><%= r %> Sterne</option><% }) %></select></label><textarea name="comment" placeholder="Kommentar optional"><%= review ? review.comment : '' %></textarea><button>Bewertung speichern</button></form></section><% } %>
<%- include('layout-bottom') %>
