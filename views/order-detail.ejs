<%- include('layout-top') %>
<h1>Bestellung</h1>

<div class="panel">
  <p><b>Kunde:</b> <%= order.full_name %> · <%= order.email %></p>
  <p><b>Zugewiesen:</b> <%= order.assigned_staff_name || 'Automatisch / keiner' %></p>
  <p><b>Status:</b> <%= order.status %> · <b>Zahlung:</b> <%= order.payment_status %> · <b>Lieferung:</b> <%= order.delivery_status %></p>
  <p><b>Zahlungsart:</b> <%= order.payment_method %></p>
  <% if (order.meeting_location || order.meeting_at || order.meeting_note) { %>
    <div class="notice"><b>Treffpunkt:</b> <%= order.meeting_location || '-' %><br><b>Zeit:</b> <%= order.meeting_at ? new Date(order.meeting_at).toLocaleString('de-DE') : '-' %><br><b>Hinweis:</b> <%= order.meeting_note || '-' %></div>
  <% } %>
  <pre><%= order.address_snapshot %></pre>
</div>

<table>
  <tr>
    <% if (isStaff) { %><th>Vorbereitet</th><% } %>
    <th>Produkt</th><th>Sorte</th><th>Menge</th><th>Preis pro Item</th><th>Summe</th>
    <% if (isStaff) { %><th>Interne Notiz</th><th>Bearbeiten</th><% } %>
  </tr>
  <% items.forEach(i => { const unit = Math.round(i.unit_price_cents*(100-i.discount_percent)/100); const note = i.current_staff_note || i.staff_note_snapshot || ''; %>
    <tr>
      <% if (isStaff) { %>
        <td><form method="post" action="/staff/order-items/<%= i.id %>/prepared" class="inline"><label class="tiny"><input type="checkbox" name="prepared" <%= i.prepared ? 'checked' : '' %> onchange="this.form.submit()"> fertig</label></form></td>
      <% } %>
      <td><%= i.product_name %> <% if (i.discount_percent) { %><span class="sale">-<%= i.discount_percent %>%</span><% } %></td>
      <td><%= i.variant_name || i.variety || '-' %></td>
      <td><%= i.quantity %></td>
      <td><%= money(unit) %></td>
      <td><%= money(unit*i.quantity) %></td>
      <% if (isStaff) { %>
        <td><% if (note) { %><pre class="staff-note"><%= note %></pre><% } else { %><span class="muted">Keine Notiz</span><% } %></td>
        <td>
          <% if (order.delivery_status !== 'Delivered') { %>
            <form method="post" action="/staff/order-items/<%= i.id %>/update" class="stack compact">
              <input name="quantity" type="number" min="1" value="<%= i.quantity %>">
              <input name="unit_price" value="<%= (i.unit_price_cents/100).toFixed(2).replace('.',',') %>">
              <button>Ändern</button>
            </form>
            <form method="post" action="/staff/order-items/<%= i.id %>/delete" onsubmit="return confirm('Artikel aus Bestellung entfernen?')"><button class="danger">Entfernen</button></form>
          <% } else { %><span class="muted">geliefert</span><% } %>
        </td>
      <% } %>
    </tr>
  <% }) %>
</table>

<% if (order.discount_cents && order.discount_cents > 0) { %><p class="sale">Rabattcode <%= order.discount_code || '' %>: -<%= money(order.discount_cents) %></p><% } %>
<% if (order.extra_cost_cents && order.extra_cost_cents > 0 && isOwner) { %><p class="muted">Extra-Kosten intern: -<%= money(order.extra_cost_cents) %> (<%= order.extra_cost_note || '-' %>)</p><% } %>
<h2>Gesamt: <%= money(order.total_cents) %></h2>

<% if (isStaff) { %>
  <form method="post" action="/staff/orders/<%= order.id %>/update" class="panel three">
    <% if (order.status==='Placed') { %>
      <button name="action" value="accept">Akzeptieren</button>
      <button name="action" value="deny" class="danger">Ablehnen</button>
    <% } else { %>
      <label>Bestellstatus<select name="status"><% ['Accepted','Denied'].forEach(s=>{ %><option <%= order.status===s?'selected':'' %>><%= s %></option><% }) %></select></label>
      <% if (order.status==='Accepted') { %>
        <label>Zahlung<select name="payment_status" <%= order.payment_method==='Bei Lieferung'?'disabled':'' %>><% (order.payment_method==='Bei Lieferung' ? ['Pay on delivery'] : ['Unpaid','Paid']).forEach(s=>{ %><option <%= order.payment_status===s?'selected':'' %>><%= s %></option><% }) %></select></label>
        <label>Lieferung<select name="delivery_status"><% ['Delivery in Progress','Delivered'].forEach(s=>{ %><option <%= order.delivery_status===s?'selected':'' %>><%= s %></option><% }) %></select></label>
      <% } %>
      <button>Aktualisieren</button>
    <% } %>
  </form>

  <section class="panel">
    <h2>Treffpunkt / Uhrzeit</h2>
    <form method="post" action="/staff/orders/<%= order.id %>/meeting" class="stack">
      <input name="meeting_location" placeholder="z.B. Bahnhof Amberg" value="<%= order.meeting_location || '' %>">
      <input name="meeting_at" type="datetime-local" value="<%= order.meeting_at ? new Date(order.meeting_at).toISOString().slice(0,16) : '' %>">
      <textarea name="meeting_note" placeholder="Zusätzliche Nachricht"><%= order.meeting_note || '' %></textarea>
      <button>Treffpunkt speichern & Kunde per Mail informieren</button>
    </form>
  </section>

  <% if (order.delivery_status !== 'Delivered') { %>
    <section class="panel">
      <h2>Artikel hinzufügen</h2>
      <form method="post" action="/staff/orders/<%= order.id %>/add-item" class="inline">
        <select name="product_id"><% productsForOrder.forEach(p=>{ %><option value="<%= p.id %>"><%= p.name %> · <%= money(p.price_cents) %></option><% }) %></select>
        <input name="quantity" type="number" min="1" value="1">
        <button>Hinzufügen</button>
      </form>
    </section>
  <% } %>

  <% if (isOwner) { %>
    <section class="panel">
      <h2>Interne Extra-Kosten</h2>
      <form method="post" action="/staff/orders/<%= order.id %>/costs" class="inline">
        <input name="extra_cost" placeholder="z.B. 3,50" value="<%= ((order.extra_cost_cents||0)/100).toFixed(2).replace('.',',') %>">
        <input name="extra_cost_note" placeholder="z.B. Lieferkosten, Freund bezahlt" value="<%= order.extra_cost_note || '' %>">
        <button>Speichern</button>
      </form>
    </section>
  <% } %>
<% } %>

<section class="panel">
  <h2>Nachrichten zur Liefertermin-Abstimmung</h2>
  <div class="chat"><% messages.forEach(m => { %><div class="msg <%= m.role %>"><b><%= m.full_name %> (<%= roleLabel(m.role) %>):</b> <%= m.body %><small><%= new Date(m.created_at).toLocaleString('de-DE') %></small></div><% }) %></div>
  <form method="post" action="/orders/<%= order.id %>/message" class="stack"><textarea name="body" required placeholder="Nachricht schreiben..."></textarea><button>Senden</button></form>
</section>

<form method="post" action="/orders/<%= order.id %>/archive"><button class="secondary">Konversation archivieren</button></form>

<% if (isOwner) { %><form method="post" action="/staff/orders/<%= order.id %>/delete" class="panel" onsubmit="return confirm('Diese Bestellung wirklich dauerhaft löschen?');"><input type="hidden" name="return_filter" value="<%= order.delivery_status === 'Delivered' ? 'Delivered' : order.status %>"><label><input type="checkbox" name="restore_stock"> Lager zurückbuchen, falls nicht geliefert</label><button class="danger">Bestellung dauerhaft löschen</button></form><% } %>

<% if (isCustomer && order.delivery_status === 'Delivered') { %>
  <section class="panel"><h2>Bewertung</h2><form method="post" action="/orders/<%= order.id %>/review" class="stack"><select name="rating"><% [5,4,3,2,1].forEach(n => { %><option value="<%= n %>" <%= review && review.rating===n?'selected':'' %>><%= n %> Sterne</option><% }) %></select><textarea name="comment"><%= review ? review.comment : '' %></textarea><button>Bewertung speichern</button></form></section>
<% } %>
<%- include('layout-bottom') %>
