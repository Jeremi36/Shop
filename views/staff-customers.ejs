<%- include('layout-top') %><h1>Nutzer</h1><p class="muted">Staff-Aktionen werden über die Owner-Berechtigungen gesteuert. Accountdatenänderungen wirken nicht rückwirkend auf Bestell-Snapshots.</p>
<div class="chips"><a class="chip <%= type==='customers'?'active':'' %>" href="/staff/customers?type=customers">Customer</a><a class="chip <%= type==='premium'?'active':'' %>" href="/staff/customers?type=premium">PremCustomer</a><a class="chip <%= type==='staff'?'active':'' %>" href="/staff/customers?type=staff">Staff/Owner</a></div>
<% if(hasPermission('can_ban_users')){ %><section class="panel"><h2>IP sperren</h2><form method="post" action="/staff/ban-ip" class="inline"><input type="hidden" name="return_type" value="<%= type %>"><input name="ip" placeholder="IP-Adresse"><input name="reason" placeholder="Grund"><button class="danger">IP sperren</button></form></section><% } %>
<table><tr><th>Name/Kontakt</th><th>Adresse</th><th>Geliefert/Guthaben</th><th>Altersstatus</th><th>Rolle</th><th>Interne Notiz</th><th>Sperre</th><th>Aktion</th></tr>
<% customers.forEach(c=>{ %><tr><td><%= c.full_name %><br><small><%= c.email %></small></td><td><%= c.street %><br><%= c.postal_code %> <%= c.city %></td><td><%= c.delivered_order_count %> geliefert<br><b><%= money(c.credit_cents||0) %></b></td><td><b><%= verificationLabel(c.verification_level) %></b><% if(hasPermission('can_verify_age')&&['customer','premcustomer'].includes(c.role)){ %><form method="post" action="/staff/users/<%= c.id %>/verification" class="stack compact"><input type="hidden" name="return_type" value="<%= type %>"><select name="verification_level"><option value="0" <%= (c.verification_level||0)===0?'selected':'' %>>Unverified</option><option value="16" <%= c.verification_level===16?'selected':'' %>>16+</option><option value="18" <%= c.verification_level===18?'selected':'' %>>18+</option></select><button>Speichern</button></form><% } %></td><td><%= roleLabel(c.role) %></td><td><form method="post" action="/staff/users/<%= c.id %>/note" class="stack compact"><input type="hidden" name="return_type" value="<%= type %>"><textarea name="internal_note"><%= c.internal_note||'' %></textarea><button>Notiz speichern</button></form></td><td><% if(c.banned){ %><span class="sale">Gesperrt</span><br><small><%= c.ban_reason||'' %></small><% } else { %><span class="muted">Nicht gesperrt</span><% } %><% if(c.temporary_suspended_until&&new Date(c.temporary_suspended_until)>new Date()){ %><br><span class="sale">Temporär bis <%= new Date(c.temporary_suspended_until).toLocaleString('de-DE') %></span><% } %><% if(hasPermission('can_ban_users')){ %><form method="post" action="/staff/users/<%= c.id %>/ban" class="stack compact"><input type="hidden" name="return_type" value="<%= type %>"><label><input type="checkbox" name="banned" <%= c.banned?'checked':'' %>> Account gesperrt</label><input name="ban_reason" value="<%= c.ban_reason||'' %>" placeholder="Grund"><label><input type="checkbox" name="ban_email" <%= c.email_banned?'checked':'' %>> E-Mail-Ban</label><label><input type="checkbox" name="ban_identity" <%= c.identity_banned?'checked':'' %>> Name+Adresse-Ban</label><button class="danger">Sperre speichern</button></form><% } %></td><td><% if(isOwner){ %><form method="post" action="/staff/users/<%= c.id %>/role" class="inline"><select name="role"><% ['owner','staff','customer','premcustomer'].forEach(r=>{ %><option value="<%= r %>" <%= c.role===r?'selected':'' %>><%= roleLabel(r) %></option><% }) %></select><button>Rolle ändern</button></form><% if(['staff','owner'].includes(c.role)){ %><form method="post" action="/staff/users/<%= c.id %>/reset-link"><button>Reset-Link senden</button></form><% } %><% } %></td></tr><% }) %></table>
<%- include('layout-bottom') %>
