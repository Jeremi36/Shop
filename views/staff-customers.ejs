<%- include('layout-top') %>
<h1>Nutzerverwaltung</h1>
<p class="muted">Kunden-E-Mail-Adressen sind erst ab Senior-Staff sichtbar. Bestellungen behalten die beim Kauf gespeicherten Kundendaten.</p>
<div class="chips"><a class="chip <%= type==='customers'?'active':'' %>" href="/staff/customers?type=customers">Normale Kunden</a><a class="chip <%= type==='premium'?'active':'' %>" href="/staff/customers?type=premium">Premium, Veteran und OG</a><a class="chip <%= type==='staff'?'active':'' %>" href="/staff/customers?type=staff">Mitarbeiter</a></div>
<% if(hasPermission('can_ban_users')){ %><section class="panel"><h2>IP-Adresse sperren</h2><form method="post" action="/staff/ban-ip" class="inline"><input type="hidden" name="return_type" value="<%= type %>"><input name="ip" placeholder="IP-Adresse"><input name="reason" placeholder="Grund"><button class="danger">IP-Adresse sperren</button></form></section><% } %>
<table><tr><th>Name und Kontakt</th><th>Bestellungen und Umsatz</th><th>Altersfreigabe</th><th>Rang</th><th>Notiz</th><th>Sperre</th><th>Aktionen</th></tr>
<% customers.forEach(c=>{ const customer=customerRoles.includes(c.role); const staff=staffRoles.includes(c.role); %><tr>
  <td><b><%= c.full_name %></b><% if(hasPermission('can_view_customer_email')||staff){ %><br><small><%= c.email %></small><% } %><% if(hasPermission('can_manage_users')){ %><br><small><%= c.street %>, <%= c.postal_code %> <%= c.city %></small><% } %></td>
  <td><% if(customer){ %><%= c.completed_orders||0 %> abgeschlossen<br><%= money(c.spent_cents||0) %> Umsatz<br><b><%= money(c.credit_cents||0) %> Guthaben</b><% } else { %>Mitarbeiterkonto<% } %></td>
  <td><% if(customer){ %><b><%= verificationLabel(c.verification_level) %></b><% if(hasPermission('can_verify_age')){ %><form method="post" action="/staff/users/<%= c.id %>/verification" class="stack compact"><input type="hidden" name="return_type" value="<%= type %>"><select name="verification_level"><option value="0" <%= (c.verification_level||0)===0?'selected':'' %>>Nicht freigegeben</option><option value="16" <%= c.verification_level===16?'selected':'' %>>16+</option><option value="18" <%= c.verification_level===18?'selected':'' %>>18+</option></select><button>Speichern</button></form><% } %><% } else { %>–<% } %></td>
  <td><b><%= roleLabel(c.role) %></b><% if(customer&&c.rank_manually_set){ %><br><small>Manuell festgelegt</small><% } %>
    <% if(customer&&hasPermission('can_change_customer_rank')){ %><form method="post" action="/staff/users/<%= c.id %>/role" class="stack compact"><select name="role"><% customerRoles.forEach(r=>{ %><option value="<%= r %>" <%= c.role===r?'selected':'' %>><%= roleLabel(r) %></option><% }) %></select><button>Kundenrang ändern</button></form><form method="post" action="/staff/users/<%= c.id %>/rank-auto"><button class="secondary">Automatische Einstufung</button></form><% } %>
    <% if(staff&&hasPermission('can_change_staff_rank')&&c.role!=='owner'){ %><form method="post" action="/staff/users/<%= c.id %>/role" class="stack compact"><select name="role"><% staffRoles.filter(r=>r!=='owner').forEach(r=>{ %><option value="<%= r %>" <%= c.role===r?'selected':'' %>><%= roleLabel(r) %></option><% }) %></select><button>Mitarbeiterrolle ändern</button></form><% } %>
    <% if(customer&&isOwner){ %><form method="post" action="/staff/users/<%= c.id %>/role" class="stack compact"><select name="role"><option value="new_staff">New-Staff</option><option value="junior_staff">Junior-Staff</option><option value="senior_staff">Senior-Staff</option><option value="co_owner">Co-Owner</option></select><button class="secondary">Zum Mitarbeiter machen</button></form><% } %>
  </td>
  <td><% if(hasPermission('can_manage_users')){ %><form method="post" action="/staff/users/<%= c.id %>/note" class="stack compact"><input type="hidden" name="return_type" value="<%= type %>"><textarea name="internal_note"><%= c.internal_note||'' %></textarea><button>Notiz speichern</button></form><% } else { %><span class="muted">Nicht sichtbar</span><% } %></td>
  <td><% if(c.banned){ %><span class="sale">Gesperrt</span><br><small><%= c.ban_reason||'' %></small><% } else { %><span class="muted">Nicht gesperrt</span><% } %><% if(c.temporary_suspended_until&&new Date(c.temporary_suspended_until)>new Date()){ %><br><span class="sale">Temporär bis <%= new Date(c.temporary_suspended_until).toLocaleString('de-DE') %></span><% } %>
    <% if(hasPermission('can_ban_users')){ %><form method="post" action="/staff/users/<%= c.id %>/ban" class="stack compact"><input type="hidden" name="return_type" value="<%= type %>"><label><input type="checkbox" name="banned" <%= c.banned?'checked':'' %>> Konto sperren</label><input name="ban_reason" value="<%= c.ban_reason||'' %>" placeholder="Grund"><label><input type="checkbox" name="ban_email" <%= c.email_banned?'checked':'' %>> E-Mail-Adresse sperren</label><label><input type="checkbox" name="ban_identity" <%= c.identity_banned?'checked':'' %>> Name und Adresse sperren</label><button class="danger">Sperre speichern</button></form><% } %>
  </td>
  <td><% if(isOwner){ %><form method="post" action="/staff/users/<%= c.id %>/reset-link"><button>Passwort-Link senden</button></form><% } %></td>
</tr><% }) %></table>
<%- include('layout-bottom') %>
