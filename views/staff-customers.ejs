<%- include('layout-top') %><h1>Kunden & Rollen</h1><p class="muted">Owner kann Rollen ändern. Staff kann diese Liste nur ansehen.</p><table><tr><th>Name</th><th>E-Mail</th><th>Ort</th><th>Gelieferte Bestellungen</th><th>Rolle</th><th>Aktion</th></tr><% customers.forEach(c=>{ %><tr><td><%= c.full_name %></td><td><%= c.email %></td><td><%= c.city %></td><td><%= c.delivered_order_count %></td><td><%= roleLabel(c.role) %></td><td><% if (isOwner) { %><form method="post" action="/staff/users/<%= c.id %>/role" class="inline"><select name="role"><% ['owner','staff','customer','premcustomer'].forEach(r=>{ %><option value="<%= r %>" <%= c.role===r?'selected':'' %>><%= roleLabel(r) %></option><% }) %></select><button>Ändern</button></form><% } else { %>Nur Owner<% } %></td></tr><% }) %></table><%- include('layout-bottom') %>
