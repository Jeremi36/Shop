<%- include('layout-top') %><h1>Nutzer</h1><p class="muted">Owner kann Rollen ändern, Accounts sperren und Passwort-Reset-Links für Staff erstellen. Staff/Owner können interne Kundennotizen speichern.</p>
<div class="chips"><a class="chip <%= type==='customers'?'active':'' %>" href="/staff/customers?type=customers">Customer</a><a class="chip <%= type==='premium'?'active':'' %>" href="/staff/customers?type=premium">PremCustomer</a><a class="chip <%= type==='staff'?'active':'' %>" href="/staff/customers?type=staff">Staff/Owner</a></div>
<% if (isOwner) { %>
<section class="panel"><h2>IP sperren</h2><form method="post" action="/staff/ban-ip" class="inline"><input type="hidden" name="return_type" value="<%= type %>"><input name="ip" placeholder="IP-Adresse"><input name="reason" placeholder="Grund"><button class="danger">IP sperren</button></form></section>
<% } %>
<table><tr><th>Name</th><th>E-Mail</th><th>Adresse</th><th>Geliefert</th><th>Rolle</th><th>Interne Notiz</th><th>Sperre</th><th>Aktion</th></tr><% customers.forEach(c=>{ %><tr>
<td><%= c.full_name %></td><td><%= c.email %></td><td><%= c.street %><br><%= c.postal_code %> <%= c.city %></td><td><%= c.delivered_order_count %></td><td><%= roleLabel(c.role) %></td>
<td><form method="post" action="/staff/users/<%= c.id %>/note" class="stack compact"><input type="hidden" name="return_type" value="<%= type %>"><textarea name="internal_note"><%= c.internal_note || '' %></textarea><button>Notiz speichern</button></form></td>
<td><% if (c.banned) { %><span class="sale">Gesperrt</span><br><small><%= c.ban_reason || '' %></small><% } else { %><span class="muted">Nicht gesperrt</span><% } %>
<% if (isOwner) { %><form method="post" action="/staff/users/<%= c.id %>/ban" class="stack compact"><input type="hidden" name="return_type" value="<%= type %>"><label><input type="checkbox" name="banned" <%= c.banned?'checked':'' %>> Account gesperrt</label><input name="ban_reason" placeholder="Grund" value="<%= c.ban_reason || '' %>"><label><input type="checkbox" name="ban_email" <%= c.email_banned?'checked':'' %>> E-Mail-Ban-Regel</label><label><input type="checkbox" name="ban_identity" <%= c.identity_banned?'checked':'' %>> Name+Adresse-Ban-Regel</label><small class="muted">Haken entfernen und speichern = Regel löschen.</small><button class="danger">Sperre speichern</button></form><% } %></td>
<td><% if (isOwner) { %><form method="post" action="/staff/users/<%= c.id %>/role" class="inline"><select name="role"><% ['owner','staff','customer','premcustomer'].forEach(r=>{ %><option value="<%= r %>" <%= c.role===r?'selected':'' %>><%= roleLabel(r) %></option><% }) %></select><button>Rolle ändern</button></form><% if (c.role==='staff' || c.role==='owner') { %><form method="post" action="/staff/users/<%= c.id %>/reset-link" class="inline"><button>Reset-Link senden</button></form><% } %><% } else { %>Nur Owner<% } %></td>
</tr><% }) %></table><%- include('layout-bottom') %>
