<%- include('layout-top') %><h1>Nutzer</h1><p class="muted">Owner kann Rollen ändern und Passwort-Reset-Links für Staff erstellen.</p>
<div class="chips"><a class="chip <%= type==='customers'?'active':'' %>" href="/staff/customers?type=customers">Customer</a><a class="chip <%= type==='premium'?'active':'' %>" href="/staff/customers?type=premium">PremCustomer</a><a class="chip <%= type==='staff'?'active':'' %>" href="/staff/customers?type=staff">Staff/Owner</a></div>
<table><tr><th>Name</th><th>E-Mail</th><th>Ort</th><th>Gelieferte Bestellungen</th><th>Rolle</th><th>Aktion</th></tr><% customers.forEach(c=>{ %><tr><td><%= c.full_name %></td><td><%= c.email %></td><td><%= c.city %></td><td><%= c.delivered_order_count %></td><td><%= roleLabel(c.role) %></td><td><% if (isOwner) { %><form method="post" action="/staff/users/<%= c.id %>/role" class="inline"><select name="role"><% ['owner','staff','customer','premcustomer'].forEach(r=>{ %><option value="<%= r %>" <%= c.role===r?'selected':'' %>><%= roleLabel(r) %></option><% }) %></select><button>Rolle ändern</button></form><% if (c.role==='staff' || c.role==='owner') { %><form method="post" action="/staff/users/<%= c.id %>/reset-link" class="inline"><button>Reset-Link senden</button></form><% } %><% } else { %>Nur Owner<% } %></td></tr><% }) %></table><%- include('layout-bottom') %>
