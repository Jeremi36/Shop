<%- include('layout-top') %>
<% const labels={open:'Offen',waiting_staff:'Wartet auf Mitarbeiter',waiting_customer:'Wartet auf Kunden',closed:'Geschlossen'}; %>
<div class="section-head"><div><span class="eyebrow">Mitarbeiterbereich</span><h1>Kundensupport</h1><p class="muted">Anfragen beantworten, zuweisen und den Bearbeitungsstatus verwalten.</p></div><a class="btn secondary" href="/staff">Zur Mitarbeiterübersicht</a></div>
<div class="chips"><% Object.keys(labels).forEach(s=>{ %><a class="chip <%= status===s?'active':'' %>" href="/staff/support?status=<%= s %>"><%= labels[s] %></a><% }) %></div>
<div class="support-list">
  <% if(!conversations.length){ %><section class="panel empty-state"><span>✓</span><h2>Keine Supportanfragen</h2><p>In diesem Bereich gibt es aktuell keine Unterhaltungen.</p></section><% } %>
  <% conversations.forEach(c=>{ %><article class="support-list-card">
    <div class="support-number">#<%= c.conversation_no %></div>
    <div><h3><%= c.subject %></h3><p><%= c.customer_name %><% if(hasPermission('can_view_customer_email')){ %> · <a href="mailto:<%= c.customer_email %>"><%= c.customer_email %></a><% } %></p><small><%= c.category %> · Aktualisiert <%= new Date(c.updated_at).toLocaleString('de-DE') %></small></div>
    <div class="support-assignee"><small>Zugewiesen</small><br><strong><%= c.staff_name||'Noch nicht zugeteilt' %></strong><br><span class="status-badge <%= c.status==='closed'?'green':(c.status==='waiting_staff'?'orange':'blue') %>"><%= supportStatusDe(c.status) %></span></div>
    <a class="btn" href="/staff/support/<%= c.id %>">Öffnen</a>
  </article><% }) %>
</div>
<%- include('layout-bottom') %>
