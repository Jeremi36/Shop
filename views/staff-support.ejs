<%- include('layout-top') %>
<h1>Kundensupport</h1>
<p class="muted">Offene Unterhaltungen werden einem Mitarbeiter zugeteilt. Kunden erhalten Antworten auch als Mitteilung auf der Website.</p>
<% const labels={open:'Offen',waiting_staff:'Wartet auf Mitarbeiter',waiting_customer:'Wartet auf Kunden',closed:'Geschlossen'}; %>
<div class="chips"><% Object.keys(labels).forEach(s=>{ %><a class="chip <%= status===s?'active':'' %>" href="/staff/support?status=<%= s %>"><%= labels[s] %></a><% }) %></div>
<table><tr><th>Nummer</th><th>Kunde</th><th>Thema</th><th>Zugewiesen</th><th>Status</th><th>Aktualisiert</th><th></th></tr>
<% conversations.forEach(c=>{ %><tr><td>#<%= c.conversation_no %></td><td><%= c.customer_name %><% if(hasPermission('can_view_customer_email')){ %><br><small><%= c.customer_email %></small><% } %></td><td><b><%= c.subject %></b><br><small><%= c.category %></small></td><td><%= c.staff_name||'Nicht zugeteilt' %></td><td><%= supportStatusDe(c.status) %></td><td><%= new Date(c.updated_at).toLocaleString('de-DE') %></td><td><a class="btn" href="/staff/support/<%= c.id %>">Öffnen</a></td></tr><% }) %>
</table>
<%- include('layout-bottom') %>
