<!doctype html>
<html lang="de">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title><%= title %> · Premium Shop</title>
  <link rel="stylesheet" href="/public/css/style.css">
</head>
<body>
<header class="top">
  <a class="brand" href="/">Premium Shop</a>
  <nav>
    <a href="/">Produkte</a>
    <a href="/bewertungen">Bewertungen</a>
    <% if (user) { %>
      <a class="role role-link" href="/rollen" title="Vorteile und Fortschritt anzeigen"><%= roleLabel(user.role) %></a>
      <a href="/account">Mein Konto</a>
      <a href="/benachrichtigungen" aria-label="Benachrichtigungen">Mitteilungen <% if (notifications) { %><span class="badge"><%= notifications %></span><% } %></a>
      <% if (isCustomer) { %>
        <a class="credit-nav" href="/account">Guthaben: <%= money(creditCents) %></a>
        <a href="/cart">Warenkorb (<%= cartCount %>)</a>
        <a href="/orders">Meine Bestellungen</a>
      <% } %>
      <% if (isStaff) { %>
        <a href="/staff">Mitarbeiterbereich <% if (staffActionCount) { %><span class="badge">!</span><% } %></a>
        <% if (hasPermission('can_manage_support')) { %><a href="/staff/support">Support <% if (supportActionCount) { %><span class="badge"><%= supportActionCount %></span><% } %></a><% } %>
      <% } %>
      <form method="post" action="/logout"><button class="secondary">Abmelden</button></form>
    <% } else { %>
      <a href="/login">Einloggen</a>
      <a class="btn" href="/register">Registrieren</a>
    <% } %>
  </nav>
</header>
<main class="wrap">
