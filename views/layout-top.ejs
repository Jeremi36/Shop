<!doctype html><html lang="de"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title><%= title %> · Premium Shop</title><link rel="stylesheet" href="/public/css/style.css"></head><body>
<header class="top"><a class="brand" href="/">Premium Shop</a><nav>
<a href="/">Produkte</a><a href="/bewertungen">Bewertungen</a>
<% if (user) { %><span class="role"><%= roleLabel(user.role) %> · <%= verificationLabel(user.verification_level) %></span><a href="/account">Mein Konto</a>
<% if (isCustomer) { %><a class="credit-nav" href="/account">Guthaben: <%= money(creditCents) %></a><a href="/cart">Warenkorb (<%= cartCount %>)</a><a href="/orders">Meine Bestellungen <% if (notifications) { %><span class="badge"><%= notifications %></span><% } %></a><% } %>
<% if (isStaff) { %><a href="/staff">Staff <% if (staffActionCount) { %><span class="badge">!</span><% } %></a><% if (hasPermission('can_manage_support')) { %><a href="/staff/support">Support <% if (supportActionCount) { %><span class="badge"><%= supportActionCount %></span><% } %></a><% } %><% } %>
<form method="post" action="/logout"><button>Logout</button></form>
<% } else { %><a href="/login">Login</a><a class="btn" href="/register">Registrieren</a><% } %>
</nav></header><main class="wrap">
