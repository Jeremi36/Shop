<%- include('layout-top') %>
<h1>Owner Einstellungen</h1>
<% if (success) { %><p class="success"><%= success %></p><% } %>
<section class="panel">
  <h2>Experimentelle Alters-/Kategorie-Sperre</h2>
  <p class="muted">Wenn aktiv, können unverified Accounts keine Kategorien kaufen, die als 16+ oder 18+ markiert sind. Staff kann Kunden im Nutzer-/Supportbereich auf 16+ oder 18+ setzen.</p>
  <form method="post" action="/staff/settings/age" class="stack">
    <label><input type="checkbox" name="enabled" <%= ageEnabled ? 'checked' : '' %>> Feature aktivieren</label>
    <button>Speichern</button>
  </form>
</section>
<%- include('layout-bottom') %>
