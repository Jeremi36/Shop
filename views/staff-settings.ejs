<%- include('layout-top') %><h1>Owner Einstellungen</h1><% if(success){ %><p class="success"><%= success %></p><% } %>
<section class="panel"><h2>Experimentelle Alters-/Kategorie-Sperre</h2><p class="muted">Wenn aktiv, können Unverified Accounts keine 16+/18+ Kategorien kaufen. Eine erneute Prüfung bei der Übergabe bleibt sinnvoll.</p><form method="post" action="/staff/settings/age" class="stack"><label><input type="checkbox" name="enabled" <%= ageEnabled?'checked':'' %>> Feature dauerhaft aktivieren</label><button>Speichern</button></form></section>
<section class="panel"><h2>Experimenteller Registrierungscode</h2><p class="muted">Das Feld erscheint nur, wenn die Alters-/Kategorie-Sperre und dieser Schalter aktiv sind. Ein Code ersetzt keine Altersprüfung.</p><form method="post" action="/staff/settings/registration-code" class="stack"><label><input type="checkbox" name="enabled" <%= registrationCodeEnabled?'checked':'' %> <%= ageEnabled?'':'disabled' %>> Code bei Registrierung verlangen</label><label>Code<input name="registration_code" value="<%= registrationCodeValue %>" autocomplete="off"></label><button>Speichern</button></form></section>
<section class="panel"><h2>Support-FAQs</h2><form method="post" action="/staff/settings/faqs" class="stack"><input name="question" required placeholder="Neue Frage"><textarea name="answer" required placeholder="Antwort"></textarea><input name="sort_order" type="number" value="50"><button>FAQ hinzufügen</button></form><hr><% faqs.forEach(f=>{ %><form method="post" action="/staff/settings/faqs/<%= f.id %>" class="stack faq-editor"><input name="question" value="<%= f.question %>" required><textarea name="answer" required><%= f.answer %></textarea><input name="sort_order" type="number" value="<%= f.sort_order %>"><label><input type="checkbox" name="active" <%= f.active?'checked':'' %>> Aktiv</label><button>FAQ speichern</button></form><% }) %></section>
<%- include('layout-bottom') %>
